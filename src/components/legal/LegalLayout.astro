---
import PageHeader from "../ui/PageHeader.astro";
import type { LegalDoc } from "../../lib/legal";

interface Props {
  doc: LegalDoc;
}
const { doc } = Astro.props;
const { kicker, title, subtitle, lastUpdated, sections, current } = doc;

const tabs: { key: LegalDoc["current"]; label: string; href: string }[] = [
  { key: "terms", label: "Terms", href: "/legal/terms" },
  { key: "privacy", label: "Privacy", href: "/legal/privacy" },
  { key: "au", label: "Acceptable use", href: "/legal/acceptable-use" },
];
const pad2 = (n: number) => String(n + 1).padStart(2, "0");
---

<div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
  <PageHeader kicker={kicker} title={title} sub={subtitle} />

  <div class="mb-7 flex flex-wrap items-center gap-3.5">
    <div class="flex gap-1 rounded-[11px] p-[3px]" style="background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);">
      {
        tabs.map((t) => (
          <a
            href={t.href}
            class="rounded-lg font-semibold"
            style={`padding:8px 16px;font-size:12.5px;letter-spacing:-0.05px;background:${t.key === current ? "var(--pd-bg)" : "transparent"};color:var(${t.key === current ? "--pd-ink" : "--pd-ink2"});`}
          >
            {t.label}
          </a>
        ))
      }
    </div>
    <div class="ml-auto flex items-center gap-2">
      <span class="font-mono uppercase" style="font-size:10px;color:var(--pd-ink3);letter-spacing:0.7px;">
        Last updated · {lastUpdated}
      </span>
      <button
        type="button"
        onclick="window.print()"
        class="inline-flex items-center gap-1.5 rounded-full font-mono font-semibold uppercase"
        style="padding:7px 12px;background:var(--pd-bg);color:var(--pd-ink2);border:0.5px solid var(--pd-hairline2);font-size:10px;letter-spacing:0.5px;cursor:pointer;"
      >
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><path d="M3.5 4 V1.5 H7.5 V4"></path><rect x="2" y="4" width="7" height="4.5" rx="0.5"></rect><rect x="3.5" y="7" width="4" height="2.5"></rect></svg>
        Print
      </button>
    </div>
  </div>

  <div class="grid items-start gap-9 lg:grid-cols-[220px_minmax(0,1fr)]">
    <!-- TOC -->
    <aside class="sticky hidden lg:block" style="top:88px;">
      <div class="mb-0.5 font-mono uppercase" style="font-size:9.5px;color:var(--pd-ink3);letter-spacing:0.7px;padding:8px 12px;">
        Contents
      </div>
      {
        sections.map((s, i) => (
          <a
            href={`#legal-${s.id}`}
            class="pd-toc relative mb-px flex w-full items-center gap-2.5 rounded-lg text-left font-medium"
            data-id={s.id}
            style="padding:8px 12px;font-size:12.5px;letter-spacing:-0.05px;color:var(--pd-ink3);"
          >
            <span class="pd-toc-bar absolute left-0 top-2 bottom-2 w-[2.5px] rounded-[2px] opacity-0" style="background:var(--pd-lilac);" />
            <span class="font-mono" style="font-size:10px;letter-spacing:0.4px;min-width:18px;color:var(--pd-ink4);">{pad2(i)}</span>
            <span>{s.title}</span>
          </a>
        ))
      }
    </aside>

    <!-- Body -->
    <article style="max-width:740px;padding-bottom:80px;">
      {
        sections.map((s, i) => (
          <section id={`legal-${s.id}`} style="margin-bottom:48px;scroll-margin-top:100px;">
            <div class="mb-3.5 flex items-baseline gap-3.5">
              <span class="font-mono font-semibold" style="font-size:11px;color:var(--pd-lilac);letter-spacing:0.7px;">
                § {pad2(i)}
              </span>
              <h2 class="font-display font-medium text-ink" style="font-size:26px;letter-spacing:-0.6px;line-height:1.15;">
                {s.title}
              </h2>
            </div>
            <div class="flex flex-col gap-3.5">
              {s.body.map((node) =>
                typeof node === "string" ? (
                  <p class="text-ink-2" style="font-size:14px;line-height:1.7;letter-spacing:-0.05px;">
                    {node}
                  </p>
                ) : "list" in node ? (
                  <ul class="flex list-none flex-col gap-2 p-0">
                    {node.list.map((li) => (
                      <li class="flex items-start gap-[11px] text-ink-2" style="font-size:14px;line-height:1.55;letter-spacing:-0.05px;">
                        <span class="mt-[9px] size-[5px] shrink-0 rounded-full" style="background:var(--pd-lilac);" />
                        <span>{li}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <div class="rounded-xl" style="padding:14px 16px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);border-left:2px solid var(--pd-lilac);">
                    <div class="mb-1 font-mono font-semibold uppercase" style="font-size:9.5px;color:var(--pd-lilac);letter-spacing:0.8px;">
                      In plain English
                    </div>
                    <div class="text-ink-2" style="font-size:13.5px;line-height:1.6;letter-spacing:-0.05px;">
                      {node.note}
                    </div>
                  </div>
                )
              )}
            </div>
          </section>
        ))
      }

      <div class="mt-10 rounded-2xl" style="padding:22px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);">
        <div class="mb-1.5 font-mono uppercase" style="font-size:10px;color:var(--pd-ink3);letter-spacing:0.7px;">Questions?</div>
        <div class="mb-1 font-display font-semibold text-ink" style="font-size:18px;letter-spacing:-0.3px;">
          We answer everything at <span style="color:var(--pd-lilac);">legal@pixiedust.app</span>.
        </div>
        <div class="text-ink-3" style="font-size:13px;line-height:1.55;">
          This is a designed example, not a real legal document — please replace with counsel-approved copy before launch.
        </div>
      </div>
    </article>
  </div>
</div>

<style>
  .pd-toc.is-active {
    color: var(--pd-ink) !important;
    font-weight: 600;
  }
  .pd-toc.is-active .pd-toc-bar {
    opacity: 1;
  }
  .pd-toc.is-active .font-mono {
    color: var(--pd-lilac) !important;
  }
</style>

<script>
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>(".pd-toc"));
  if (links.length) {
    const ids = links.map((l) => l.dataset.id!);
    const setActive = () => {
      const y = window.scrollY + 140;
      let cur = ids[0];
      for (const id of ids) {
        const el = document.getElementById("legal-" + id);
        if (el && el.offsetTop <= y) cur = id;
      }
      links.forEach((l) => l.classList.toggle("is-active", l.dataset.id === cur));
    };
    window.addEventListener("scroll", setActive, { passive: true });
    links.forEach((l) =>
      l.addEventListener("click", (e) => {
        e.preventDefault();
        document.getElementById("legal-" + l.dataset.id)?.scrollIntoView({ block: "start", behavior: "smooth" });
      })
    );
    setActive();
  }
</script>
