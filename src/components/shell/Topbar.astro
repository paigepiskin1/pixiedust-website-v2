---
import Logo from "./Logo.astro";

const iconBtn =
  "pd-icon-btn flex items-center justify-center rounded-[10px] transition-colors";
---

<header
  class="sticky top-0 z-50 flex shrink-0 items-center"
  style="height:var(--pd-topbar-h);border-bottom:0.5px solid var(--pd-hairline);background:color-mix(in srgb, var(--pd-bg) 82%, transparent);backdrop-filter:blur(20px);"
>
  <!-- mobile row -->
  <div class="flex w-full items-center gap-2 px-3.5 md:hidden">
    <button
      type="button"
      id="pd-drawer-open"
      class="flex size-[38px] items-center justify-center rounded-[10px] text-ink"
      style="background:transparent;border:none;cursor:pointer;"
      aria-label="Open menu"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M3 5 H15 M3 9 H15 M3 13 H15"></path></svg>
    </button>
    <Logo size={20} />
    <div class="flex-1"></div>
    <a href="/search" class={`${iconBtn} size-9 text-ink-2`} aria-label="Search">
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="6.5" cy="6.5" r="4.5"></circle><path d="M10 10 L13.5 13.5"></path></svg>
    </a>
    <a
      href="/credits"
      class="rounded-[9px] font-bold"
      style="padding:7px 12px;background:var(--pd-ink);color:var(--pd-bg);font-size:12px;letter-spacing:-0.1px;">Upgrade</a
    >
  </div>

  <!-- desktop row -->
  <div class="hidden w-full items-center gap-3.5 md:flex" style="padding:0 28px;">
    <form
      id="pd-search-form"
      class="pd-search flex items-center gap-2.5"
      style="flex:1;max-width:520px;height:38px;padding:0 14px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);border-radius:10px;transition:all 120ms;"
      action="/search"
      method="get"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="var(--pd-ink3)" stroke-width="1.5" stroke-linecap="round"><circle cx="6" cy="6" r="4.5"></circle><path d="M9.5 9.5L13 13"></path></svg>
      <input
        type="text"
        name="q"
        placeholder="Search presets, templates, looks…"
        class="min-w-0 flex-1 bg-transparent text-ink outline-none"
        style="font-size:13px;letter-spacing:-0.1px;"
        autocomplete="off"
      />
      <kbd
        class="font-mono"
        style="padding:2px 6px;border-radius:5px;background:var(--pd-bg);border:0.5px solid var(--pd-hairline);font-size:10px;color:var(--pd-ink3);letter-spacing:0.5px;">⌘K</kbd
      >
    </form>

    <div class="flex-1"></div>

    <button type="button" class={`${iconBtn} size-9 text-ink-2`} data-toast="What's new — coming soon" data-accent="var(--pd-lilac)" aria-label="What's new">
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><path d="M3 6a4.5 4.5 0 0 1 9 0v3l1 1.5H2L3 9z"></path><path d="M6 12.5a1.5 1.5 0 0 0 3 0"></path></svg>
    </button>
    <a href="/feedback" class={`${iconBtn} size-9 text-ink-2`} aria-label="Help & feedback" title="Help & feedback">
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><circle cx="7.5" cy="7.5" r="6"></circle><path d="M5.5 6a2 2 0 0 1 4 0c0 1-2 1.5-2 2.5"></path><circle cx="7.5" cy="11" r="0.4" fill="currentColor"></circle></svg>
    </a>
    <button
      type="button"
      data-toast="Invite link copied · just kidding 😉"
      data-accent="var(--pd-mint)"
      class="rounded-[10px] font-medium text-ink"
      style="padding:8px 14px;background:transparent;border:0.5px solid var(--pd-hairline2);cursor:pointer;font-size:12.5px;letter-spacing:-0.1px;">Invite</button
    >
    <a
      href="/credits"
      class="rounded-[10px] font-bold"
      style="padding:8px 14px;background:var(--pd-ink);color:var(--pd-bg);font-size:12.5px;letter-spacing:-0.1px;">Upgrade</a
    >
  </div>
</header>

<style>
  .pd-icon-btn {
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .pd-icon-btn:hover {
    background: var(--pd-bg2);
  }
  .pd-search:focus-within {
    background: var(--pd-bg3);
    border-color: var(--pd-hairline3);
  }
</style>

<script is:inline>
  (function () {
    // Toast buttons
    document.querySelectorAll("[data-toast]").forEach((b) => {
      b.addEventListener("click", () => {
        window.pdToast &&
          window.pdToast(b.getAttribute("data-toast"), { accent: b.getAttribute("data-accent") || undefined });
      });
    });
    // Open mobile drawer
    const open = document.getElementById("pd-drawer-open");
    if (open) open.addEventListener("click", () => window.dispatchEvent(new CustomEvent("pd-open-drawer")));
    // ⌘K / Ctrl+K focuses search
    window.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
        const input = document.querySelector('#pd-search-form input[name="q"]');
        if (input) {
          e.preventDefault();
          input.focus();
        }
      }
    });
  })();
</script>
