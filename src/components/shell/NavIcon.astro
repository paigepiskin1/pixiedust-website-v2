---
import type { IconName } from "../../lib/nav";

interface Props {
  name: IconName;
  size?: number;
}

const { name, size = 16 } = Astro.props;
// All paths drawn at viewBox 0 0 16 16, stroke = currentColor so the parent controls color.
const paths: Record<IconName, string> = {
  home: '<path d="M2 7l6-5 6 5v7H2z"/><path d="M6 14V9h4v5"/>',
  trending: '<path d="M2 12l4-4 3 3 5-6"/><path d="M10 5h4v4"/>',
  gallery:
    '<rect x="2" y="2" width="5" height="5" rx="1"/><rect x="9" y="2" width="5" height="5" rx="1"/><rect x="2" y="9" width="5" height="5" rx="1"/><rect x="9" y="9" width="5" height="5" rx="1"/>',
  wand: '<path d="M3 13l9-9 1 1-9 9z"/><path d="M11 4l1-1 1 1-1 1zM6 14l1-1M14 9l-1-1"/>',
  camera:
    '<rect x="2" y="4" width="12" height="9" rx="1.5"/><circle cx="8" cy="8.5" r="2.5"/><path d="M5 4l1-1.5h4L11 4"/>',
  sparkle: '<path d="M8 2v3M8 11v3M2 8h3M11 8h3M4 4l2 2M10 10l2 2M12 4l-2 2M4 12l2-2"/>',
  film: '<rect x="2" y="3" width="12" height="10" rx="1"/><path d="M5 3v10M11 3v10M2 6h3M11 6h3M2 10h3M11 10h3"/>',
  motion:
    '<path d="M2.5 8a5.5 5.5 0 0 1 5.5-5.5M13.5 8a5.5 5.5 0 0 1-5.5 5.5"/><path d="M11 2.5l2 .5-1 2M5 13.5l-2-.5 1-2"/>',
  shirt: '<path d="M5 2l3 1.5L11 2l3 2.5-2 2v7H4V6.5l-2-2z"/>',
  beauty: '<path d="M8 2c2.5 0 4.5 2 4.5 4.5S10.5 12 8 14c-2.5-2-4.5-5-4.5-7.5S5.5 2 8 2z"/><circle cx="8" cy="6" r="1"/>',
  ad: '<path d="M3 5v6l8 3V2z"/><path d="M11 6v4M3 8h2"/>',
};
---

<svg
  width={size}
  height={size}
  viewBox="0 0 16 16"
  fill="none"
  stroke="currentColor"
  stroke-width="1.4"
  stroke-linecap="round"
  stroke-linejoin="round"
  set:html={paths[name]}
/>
