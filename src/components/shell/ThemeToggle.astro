---
// Segmented dark/light toggle. Persists to localStorage['pd-web-theme'];
// Base.astro restores it before paint. Mirrors pdSetTheme from web-tokens.jsx.
---

<div
  class="pd-theme-toggle flex gap-1 rounded-[11px] p-[3px]"
  style="background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);"
>
  <button
    type="button"
    data-theme-set="dark"
    class="flex flex-1 items-center justify-center gap-[5px] rounded-lg py-1.5 px-2 font-semibold capitalize"
    style="font-size:11px;letter-spacing:-0.1px;"
  >
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"
      ><path d="M11.5 8.2A4.5 4.5 0 0 1 5.8 2.5a5 5 0 1 0 5.7 5.7z"></path></svg
    >dark
  </button>
  <button
    type="button"
    data-theme-set="light"
    class="flex flex-1 items-center justify-center gap-[5px] rounded-lg py-1.5 px-2 font-semibold capitalize"
    style="font-size:11px;letter-spacing:-0.1px;"
  >
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"
      ><circle cx="7" cy="7" r="2.5"></circle><path
        d="M7 1v1.5M7 11.5V13M1 7h1.5M11.5 7H13M2.5 2.5l1 1M10.5 10.5l1 1M2.5 11.5l1-1M10.5 3.5l1-1"></path></svg
    >light
  </button>
</div>

<style>
  .pd-theme-toggle button {
    background: transparent;
    color: var(--pd-ink3);
    border: none;
    cursor: pointer;
    transition: background 120ms, color 120ms;
  }
  .pd-theme-toggle button[data-active="true"] {
    background: var(--pd-bg3);
    color: var(--pd-ink);
  }
</style>

<script is:inline>
  (function () {
    function current() {
      return document.documentElement.getAttribute("data-theme") === "light" ? "light" : "dark";
    }
    function sync() {
      const t = current();
      document.querySelectorAll(".pd-theme-toggle button[data-theme-set]").forEach((b) => {
        b.setAttribute("data-active", String(b.getAttribute("data-theme-set") === t));
      });
    }
    document.querySelectorAll(".pd-theme-toggle button[data-theme-set]").forEach((b) => {
      b.addEventListener("click", () => {
        const next = b.getAttribute("data-theme-set");
        const el = document.documentElement;
        if (next === "light") el.setAttribute("data-theme", "light");
        else el.removeAttribute("data-theme");
        try {
          localStorage.setItem("pd-web-theme", next);
        } catch (e) {}
        window.dispatchEvent(new CustomEvent("pd-theme", { detail: next }));
        sync();
      });
    });
    window.addEventListener("pd-theme", sync);
    sync();
  })();
</script>
