---
/**
 * Shared template field panel — renders the exact same inputs used in the
 * studio. Accepts an optional `fields` prop (server-side) OR can be
 * initialized from JS via `window.pdInitFieldPanel(root, fields)` for
 * dynamic use (admin editor test panel).
 *
 * Usage (server-side, studio):
 *   <FieldPanel fields={template.fields} />
 *
 * Usage (dynamic / admin test panel):
 *   <div id="my-panel"></div>
 *   window.pdInitFieldPanel(document.getElementById('my-panel'), parsedFields);
 *   const vals = window.pdCollectFieldValues(document.getElementById('my-panel'));
 */
import type { TemplateField } from "../lib/templates";

interface Props {
  fields?: TemplateField[];
  id?: string;
}

const { fields = [], id } = Astro.props;

function formatAccept(accept: string) {
  return accept.replace(/image\//g, "").replace(/video\//g, "").replace(/,\s*/g, ", ").toUpperCase();
}
---

<div class="pd-field-panel flex flex-col gap-4" id={id}>
  {fields.map((f) => (
    f.type === "file" ? (
      <div class="block">
        <span class="mb-1.5 block font-medium text-ink" style="font-size:12.5px;">{f.label}{f.required ? " *" : ""}</span>
        <div class="pd-file-wrap" data-fieldkey={f.key} data-multiple={f.multiple ? "true" : undefined} data-max={f.multiple ? String(f.max ?? 4) : undefined}>
          <div class="pd-upload-zone relative flex w-full cursor-pointer flex-col items-center gap-1 rounded-xl text-center" style="padding:18px 14px;background:var(--pd-bg);border:1px dashed var(--pd-hairline2);transition:border-color 0.15s,background 0.15s;">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="var(--pd-ink3)" stroke-width="1.4" stroke-linecap="round"><path d="M10 13V7M7 10l3-3 3 3"/><rect x="3" y="3" width="14" height="14" rx="3"/></svg>
            <span style="font-size:12px;color:var(--pd-ink3);pointer-events:none;">Click or drag to upload</span>
            {f.accept && <span style="font-size:10.5px;color:var(--pd-ink4);pointer-events:none;">{formatAccept(f.accept)} · {f.multiple ? `up to ${f.max ?? 4} files` : "1 file max"}</span>}
            <input data-field={f.key} type="file" accept={f.accept} multiple={f.multiple || undefined} class="absolute inset-0 cursor-pointer opacity-0" style="z-index:1;" />
          </div>
          {f.multiple ? (
            <div class="pd-multi-previews" style="display:none;flex-wrap:wrap;gap:6px;margin-top:8px;"></div>
          ) : (
            <div class="pd-file-preview hidden overflow-hidden rounded-xl" style="background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);margin-top:4px;">
              <img class="pd-preview-img block w-full" style="max-height:160px;object-fit:cover;" alt="" />
              <div class="flex items-center justify-between gap-2" style="padding:7px 10px;border-top:0.5px solid var(--pd-hairline);">
                <span class="pd-preview-status truncate" style="font-size:11px;color:var(--pd-ink3);"></span>
                <button type="button" class="pd-file-clear flex shrink-0 items-center justify-center rounded-full" style="width:20px;height:20px;background:var(--pd-bg3);border:0.5px solid var(--pd-hairline2);color:var(--pd-ink3);font-size:10px;cursor:pointer;" aria-label="Remove">✕</button>
              </div>
            </div>
          )}
        </div>
        {f.help && <span class="mt-1 block text-ink-4" style="font-size:11px;">{f.help}</span>}
      </div>
    ) : (
      <label class="block">
        <span class="mb-1.5 block font-medium text-ink" style="font-size:12.5px;">{f.label}{f.required ? " *" : ""}</span>
        {f.type === "textarea" ? (
          <textarea data-field={f.key} rows="3" placeholder={f.placeholder} class="w-full rounded-xl text-ink outline-none" style="padding:11px 13px;background:var(--pd-bg);border:0.5px solid var(--pd-hairline2);font-size:13.5px;line-height:1.5;resize:vertical;">{String(f.default ?? "")}</textarea>
        ) : f.type === "select" ? (
          <select data-field={f.key} class="w-full rounded-xl text-ink outline-none" style="padding:11px 13px;background:var(--pd-bg);border:0.5px solid var(--pd-hairline2);font-size:13.5px;">
            {(f.options ?? []).map((o) => <option value={o.value} selected={o.value === String(f.default ?? "")}>{o.label}</option>)}
          </select>
        ) : f.type === "number" ? (
          <input data-field={f.key} type="number" min={f.min} max={f.max} step={f.step} value={f.default as number | undefined} class="w-full rounded-xl text-ink outline-none" style="padding:11px 13px;background:var(--pd-bg);border:0.5px solid var(--pd-hairline2);font-size:13.5px;" />
        ) : (
          <input data-field={f.key} type={f.type === "url" ? "url" : f.type === "email" ? "email" : "text"} placeholder={f.placeholder} value={String(f.default ?? "")} class="w-full rounded-xl text-ink outline-none" style="padding:11px 13px;background:var(--pd-bg);border:0.5px solid var(--pd-hairline2);font-size:13.5px;" />
        )}
        {f.help && <span class="mt-1 block text-ink-4" style="font-size:11px;">{f.help}</span>}
      </label>
    )
  ))}
</div>

<script>
/**
 * Shared field panel runtime — uploaded file URLs, drag-and-drop, previews.
 * Exposed globally so admin editor can call it dynamically.
 *
 * window.pdInitFieldPanel(root: HTMLElement, fileUrls: Record) → void
 *   Wires all file inputs in `root`. fileUrls is written to on upload.
 *
 * window.pdRenderFields(container: HTMLElement, fields: any[]) → void
 *   Dynamically generates field HTML into container (for JS-only use).
 *
 * window.pdCollectFieldValues(root: HTMLElement, fileUrls: Record) → Record
 *   Returns all current field values (text + uploaded file URLs).
 */

// ── HTML generator (used by admin editor to re-render dynamically) ────────────
(window as any).pdRenderFields = function(container: HTMLElement, fields: any[]) {
  if (!Array.isArray(fields) || !fields.length) {
    container.innerHTML = '<div style="font-size:12px;color:var(--pd-ink3);">No fields defined yet — edit fields_json above and they\'ll appear here.</div>';
    return;
  }
  const S = "padding:11px 13px;background:var(--pd-bg);border:0.5px solid var(--pd-hairline2);border-radius:12px;font-size:13.5px;color:var(--pd-ink);outline:none;width:100%;box-sizing:border-box;";
  container.innerHTML = fields.map((f: any) => {
    const key = String(f.key ?? "");
    const label = String(f.label ?? key);
    const type = String(f.type ?? "text");
    const ph = String(f.placeholder ?? "");
    const def = f.default != null ? String(f.default) : "";
    const help = f.help ? `<span style="display:block;margin-top:4px;font-size:11px;color:var(--pd-ink4);">${escHtml(f.help)}</span>` : "";

    if (type === "file") {
      const isMulti = !!f.multiple;
      const maxFiles = Number(f.max ?? 4);
      const accept = String(f.accept ?? "");
      const acceptLabel = accept ? accept.replace(/image\//g,"").replace(/video\//g,"").replace(/,\s*/g,", ").toUpperCase() : "";
      return `<div>
        <span style="display:block;margin-bottom:6px;font-size:12.5px;font-weight:500;color:var(--pd-ink);">${escHtml(label)}${f.required?" *":""}</span>
        <div class="pd-file-wrap" data-fieldkey="${key}"${isMulti?` data-multiple="true" data-max="${maxFiles}"`:""}">
          <div class="pd-upload-zone" style="position:relative;display:flex;flex-direction:column;align-items:center;gap:4px;padding:18px 14px;background:var(--pd-bg);border:1px dashed var(--pd-hairline2);border-radius:12px;cursor:pointer;text-align:center;transition:border-color .15s,background .15s;">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="var(--pd-ink3)" stroke-width="1.4" stroke-linecap="round"><path d="M10 13V7M7 10l3-3 3 3"/><rect x="3" y="3" width="14" height="14" rx="3"/></svg>
            <span style="font-size:12px;color:var(--pd-ink3);pointer-events:none;">Click or drag to upload</span>
            ${accept?`<span style="font-size:10.5px;color:var(--pd-ink4);pointer-events:none;">${acceptLabel} · ${isMulti?`up to ${maxFiles} files`:"1 file max"}</span>`:""}
            <input data-field="${key}" type="file"${accept?` accept="${accept}"`:""}${isMulti?" multiple":""} style="position:absolute;inset:0;opacity:0;cursor:pointer;z-index:1;" />
          </div>
          ${isMulti
            ? `<div class="pd-multi-previews" style="display:none;flex-wrap:wrap;gap:6px;margin-top:8px;"></div>`
            : `<div class="pd-file-preview" style="display:none;overflow:hidden;border-radius:12px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);margin-top:4px;">
                <img class="pd-preview-img" style="display:block;width:100%;max-height:160px;object-fit:cover;" alt="" />
                <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;padding:7px 10px;border-top:0.5px solid var(--pd-hairline);">
                  <span class="pd-preview-status" style="font-size:11px;color:var(--pd-ink3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></span>
                  <button type="button" class="pd-file-clear" style="flex-shrink:0;width:20px;height:20px;border-radius:50%;background:var(--pd-bg3);border:0.5px solid var(--pd-hairline2);color:var(--pd-ink3);font-size:10px;cursor:pointer;line-height:1;">✕</button>
                </div>
              </div>`
          }
        </div>
        ${help}
      </div>`;
    }

    let input = "";
    if (type === "textarea") {
      input = `<textarea data-field="${key}" rows="3" placeholder="${escAttr(ph)}" style="${S}line-height:1.5;resize:vertical;">${escHtml(def)}</textarea>`;
    } else if (type === "select" && Array.isArray(f.options)) {
      const opts = f.options.map((o: any) => `<option value="${escAttr(String(o.value??o))}"${String(o.value??o)===def?" selected":""}>${escHtml(String(o.label??o.value??o))}</option>`).join("");
      input = `<select data-field="${key}" style="${S}">${opts}</select>`;
    } else if (type === "number") {
      input = `<input data-field="${key}" type="number"${f.min!=null?` min="${f.min}"`:""}${f.max!=null?` max="${f.max}"`:""}${f.step!=null?` step="${f.step}"`:""}  value="${escAttr(def)}" style="${S}" />`;
    } else {
      const t = type === "url" ? "url" : type === "email" ? "email" : "text";
      input = `<input data-field="${key}" type="${t}" placeholder="${escAttr(ph)}" value="${escAttr(def)}" style="${S}" />`;
    }
    return `<label style="display:block;">
      <span style="display:block;margin-bottom:6px;font-size:12.5px;font-weight:500;color:var(--pd-ink);">${escHtml(label)}${f.required?" *":""}</span>
      ${input}${help}
    </label>`;
  }).join("");
};

function escHtml(s: string) { return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;"); }
function escAttr(s: string) { return s.replace(/"/g,"&quot;").replace(/'/g,"&#39;"); }

// ── File upload wiring ────────────────────────────────────────────────────────
(window as any).pdInitFieldPanel = function(root: HTMLElement, fileUrls: Record<string, any>) {

  async function handleUpload(file: File, key: string,
    zone: HTMLElement|null, preview: HTMLElement|null,
    previewImg: HTMLImageElement|null, status: HTMLElement|null
  ) {
    const localUrl = URL.createObjectURL(file);
    if (previewImg) previewImg.src = localUrl;
    if (zone) zone.style.display = "none";
    if (preview) preview.style.display = "";
    if (status) { status.textContent = "Uploading…"; status.style.color = "var(--pd-ink3)"; }
    const fd = new FormData();
    fd.append("file", file);
    try {
      const r = await fetch("/api/upload", { method: "POST", body: fd });
      const d = await r.json();
      if (r.ok) {
        fileUrls[key] = d.url;
        if (previewImg) previewImg.src = d.url;
        URL.revokeObjectURL(localUrl);
        if (status) { status.textContent = "✓ Uploaded"; status.style.color = "var(--pd-mint)"; }
      } else {
        if (status) { status.textContent = d.error || "Upload failed"; status.style.color = "var(--pd-pink)"; }
        delete fileUrls[key];
      }
    } catch {
      if (status) { status.textContent = "Upload failed"; status.style.color = "var(--pd-pink)"; }
      delete fileUrls[key];
    }
  }

  root.querySelectorAll<HTMLInputElement>('input[type="file"][data-field]').forEach((el) => {
    const key = el.dataset.field!;
    const wrap = el.closest(".pd-file-wrap") as HTMLElement|null;
    const isMulti = wrap?.dataset.multiple === "true";
    const maxFiles = Number(wrap?.dataset.max ?? 4);
    const zone = wrap?.querySelector<HTMLElement>(".pd-upload-zone");

    if (isMulti) {
      const thumbsEl = wrap?.querySelector<HTMLElement>(".pd-multi-previews");
      let urls: string[] = [];

      function syncZone() {
        if (zone) zone.style.display = urls.length >= maxFiles ? "none" : "";
        if (thumbsEl) thumbsEl.style.display = urls.length > 0 ? "flex" : "none";
        fileUrls[key] = urls.length > 0 ? [...urls] : [];
      }

      async function addFile(file: File) {
        if (urls.length >= maxFiles) return;
        const thumb = document.createElement("div");
        thumb.style.cssText = "position:relative;width:70px;height:70px;border-radius:10px;overflow:hidden;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);flex-shrink:0;";
        const img = document.createElement("img");
        img.style.cssText = "width:100%;height:100%;object-fit:cover;";
        img.src = URL.createObjectURL(file);
        const spinner = document.createElement("div");
        spinner.style.cssText = "position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.4);font-size:9px;color:#fff;";
        spinner.textContent = "↑";
        thumb.appendChild(img); thumb.appendChild(spinner);
        thumbsEl?.appendChild(thumb);
        if (thumbsEl) thumbsEl.style.display = "flex";

        const fd = new FormData(); fd.append("file", file);
        try {
          const r = await fetch("/api/upload", { method: "POST", body: fd });
          const d = await r.json();
          if (r.ok) {
            urls.push(d.url); img.src = d.url; URL.revokeObjectURL(img.src);
            spinner.remove();
            const x = document.createElement("button");
            x.type = "button"; x.textContent = "✕";
            x.style.cssText = "position:absolute;top:3px;right:3px;width:16px;height:16px;border-radius:50%;background:rgba(0,0,0,0.65);color:#fff;font-size:9px;border:none;cursor:pointer;line-height:1;";
            x.addEventListener("click", () => { urls = urls.filter(u => u !== d.url); thumb.remove(); syncZone(); });
            thumb.appendChild(x);
          } else { thumb.remove(); }
        } catch { thumb.remove(); }
        syncZone();
      }

      const hl  = () => { if (zone) { zone.style.borderColor="var(--pd-lilac)"; zone.style.background="color-mix(in srgb,var(--pd-lilac) 6%,var(--pd-bg))"; }};
      const uhl = () => { if (zone) { zone.style.borderColor=""; zone.style.background=""; }};
      let dc = 0;
      el.addEventListener("dragenter", e => { e.preventDefault(); if(++dc===1) hl(); });
      el.addEventListener("dragleave", () => { if(--dc===0) uhl(); });
      el.addEventListener("dragover",  e => e.preventDefault());
      el.addEventListener("drop", async e => { e.preventDefault(); dc=0; uhl(); for(const f of Array.from((e as DragEvent).dataTransfer?.files??[]).slice(0,maxFiles-urls.length)) await addFile(f); });
      el.addEventListener("change", async () => { const files=Array.from(el.files??[]).slice(0,maxFiles-urls.length); el.value=""; for(const f of files) await addFile(f); });
      syncZone();
      return;
    }

    // Single-file
    const preview    = wrap?.querySelector<HTMLElement>(".pd-file-preview");
    const previewImg = wrap?.querySelector<HTMLImageElement>(".pd-preview-img");
    const status     = wrap?.querySelector<HTMLElement>(".pd-preview-status");
    const clearBtn   = wrap?.querySelector<HTMLElement>(".pd-file-clear");

    el.addEventListener("change", async () => { const f=el.files?.[0]; if(f) await handleUpload(f, key, zone??null, preview??null, previewImg??null, status??null); });
    let dc2 = 0;
    const hl2  = () => { if(zone){zone.style.borderColor="var(--pd-lilac)";zone.style.background="color-mix(in srgb,var(--pd-lilac) 6%,var(--pd-bg))";} };
    const uhl2 = () => { if(zone){zone.style.borderColor="";zone.style.background="";} };
    el.addEventListener("dragenter", e=>{e.preventDefault();if(++dc2===1)hl2();});
    el.addEventListener("dragleave",  ()=>{if(--dc2===0)uhl2();});
    el.addEventListener("dragover",   e=>e.preventDefault());
    el.addEventListener("drop", async e=>{e.preventDefault();dc2=0;uhl2();const f=(e as DragEvent).dataTransfer?.files?.[0];if(f)await handleUpload(f,key,zone??null,preview??null,previewImg??null,status??null);});
    clearBtn?.addEventListener("click",()=>{delete fileUrls[key];el.value="";if(previewImg)previewImg.src="";if(preview)preview.style.display="none";if(zone)zone.style.display="";});
  });
};

// ── Collect all field values ──────────────────────────────────────────────────
(window as any).pdCollectFieldValues = function(root: HTMLElement, fileUrls: Record<string, any>): Record<string, any> {
  const out: Record<string, any> = {};
  root.querySelectorAll<HTMLElement>("[data-field]").forEach((el) => {
    const key = (el as HTMLInputElement).dataset.field!;
    if ((el as HTMLInputElement).type === "file") {
      if (fileUrls[key] != null) out[key] = fileUrls[key];
      return;
    }
    out[key] = (el as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement).value;
  });
  return out;
};

// Auto-init any .pd-field-panel already in the DOM (server-rendered, e.g. studio)
document.querySelectorAll<HTMLElement>(".pd-field-panel[id]").forEach((panel) => {
  const fileUrls: Record<string, any> = {};
  (panel as any)._pdFileUrls = fileUrls;
  (window as any).pdInitFieldPanel(panel, fileUrls);
});
</script>
