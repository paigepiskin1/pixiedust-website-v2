---
import CatalogCard from "./CatalogCard.astro";
import type { CatalogItem } from "../../lib/catalog";

interface Props {
  items: CatalogItem[];
  categories?: string[];
  aspect?: string;
}
const { items, categories, aspect = "1 / 1.3" } = Astro.props;
---

<div class="pd-catalog">
  {
    categories && (
      <div class="mb-6 flex flex-wrap gap-2">
        {categories.map((o, i) => (
          <button
            type="button"
            class="pd-chip rounded-full font-semibold"
            data-cat={o}
            data-active={i === 0 ? "true" : "false"}
            style="padding:8px 16px;font-size:12.5px;letter-spacing:-0.1px;cursor:pointer;transition:all 120ms;"
          >
            {o}
          </button>
        ))}
      </div>
    )
  }

  <div class="grid grid-cols-2 gap-3.5 sm:grid-cols-3 lg:grid-cols-4">
    {items.map((it) => <CatalogCard item={it} aspect={aspect} />)}
  </div>
</div>

<style>
  .pd-chip {
    background: var(--pd-bg2);
    color: var(--pd-ink2);
    border: 0.5px solid var(--pd-hairline);
  }
  .pd-chip[data-active="true"] {
    background: var(--pd-ink);
    color: var(--pd-bg);
    border-color: transparent;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".pd-catalog").forEach((root) => {
    const chips = Array.from(root.querySelectorAll<HTMLElement>(".pd-chip"));
    if (!chips.length) return;
    const cards = Array.from(root.querySelectorAll<HTMLElement>(".pd-cat-card"));
    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const cat = chip.dataset.cat || "All";
        chips.forEach((c) => c.setAttribute("data-active", String(c === chip)));
        cards.forEach((card) => {
          const show = cat === "All" || card.dataset.cat === cat;
          card.style.display = show ? "" : "none";
        });
      });
    });
  });
</script>
