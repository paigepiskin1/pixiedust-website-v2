---
import AppShell from "../layouts/AppShell.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import FilterableCatalog from "../components/catalog/FilterableCatalog.astro";
import { AVATAR } from "../lib/catalog";
---

<AppShell title="Avatar Studio — PixieDust">
  <div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
    <PageHeader
      kicker="No training needed · instant"
      title="Avatar Studio"
      sub="Build a custom model from scratch — or restyle yourself into any aesthetic. No setup, no LoRA, no waiting."
    />
    <FilterableCatalog items={AVATAR} aspect="1 / 1.3" />
  </div>
</AppShell>
