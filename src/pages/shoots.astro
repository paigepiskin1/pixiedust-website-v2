---
import AppShell from "../layouts/AppShell.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import FeatureBanner from "../components/home/FeatureBanner.astro";
import FilterableCatalog from "../components/catalog/FilterableCatalog.astro";
import { SHOOTS, SHOOT_CATS } from "../lib/catalog";
---

<AppShell title="AI Photoshoots — PixieDust">
  <div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
    <PageHeader
      kicker="Themed packs · 12–30 frames"
      title="AI Photoshoots"
      sub="Pick a vibe. We generate a full shoot of you — no model training, no setup."
    />
    <div class="mb-7">
      <FeatureBanner
        tone="lilac"
        kicker="Avatar Studio · No training"
        title={"Build a model.\nOr become one."}
        sub="Hair · makeup · skin · fit"
        ctaLabel="Open Avatar Studio"
        accent="var(--pd-lilac)"
        href="/avatar"
        height={240}
      />
    </div>
    <FilterableCatalog items={SHOOTS} categories={SHOOT_CATS} aspect="1 / 1.3" />
  </div>
</AppShell>
