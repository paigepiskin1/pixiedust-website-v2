---
export const prerender = false;
import AppShell from "../layouts/AppShell.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import FilterableCatalog from "../components/catalog/FilterableCatalog.astro";
import { listTemplates, templateToCard } from "../lib/templates";
import { BEAUTY_CATS } from "../lib/catalog";

const db = Astro.locals.runtime.env.DB;
const items = (await listTemplates(db, { kind: "beauty" })).map(templateToCard);
---

<AppShell title="AI Beauty Studio — PixieDust" description="Enhance portraits with AI — change hairstyles, apply makeup, and transform your look with realistic beauty templates." credits={Astro.locals.user?.credits ?? 47}>
  <div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
    <PageHeader
      kicker="Hair · makeup · skin · 1 cr"
      title="Beauty Studio"
      sub="Try a look in seconds. Mix and match — every output stays in your gallery."
    />
    <FilterableCatalog items={items} categories={BEAUTY_CATS} aspect="9 / 12" />
  </div>
</AppShell>
