---
import AppShell from "../layouts/AppShell.astro";
import Media from "../components/ui/Media.astro";
import Pill from "../components/ui/Pill.astro";
import CreditChip from "../components/ui/CreditChip.astro";

const tiles = [
  { tone: "lilac", label: "Presets", sub: "120+ looks" },
  { tone: "teal", label: "Photoshoots", sub: "Editorial packs" },
  { tone: "pink", label: "Video", sub: "Cinematic" },
  { tone: "mint", label: "Beauty", sub: "Hair · makeup" },
  { tone: "amber", label: "Ad Studio", sub: "Commercial" },
  { tone: "dusk", label: "Avatar", sub: "Build a base" },
] as const;
---

<AppShell title="PixieDust — Home">
  <div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
    <div class="mb-2 flex items-center gap-3">
      <Pill color="var(--pd-lilac)" label="Phase 2 · Shell" />
      <CreditChip cr={47} />
    </div>

    <h1 class="font-display font-medium tracking-tight text-ink" style="font-size:38px;line-height:1.05;letter-spacing:-1px;">
      Welcome back
    </h1>
    <p class="mt-1 text-ink-2" style="font-size:14.5px;">
      The app shell is live — sidebar, topbar, mobile drawer, and theme switching.
      Real pages land in Phase 3.
    </p>

    <div class="mt-7 grid grid-cols-2 gap-4 sm:grid-cols-3">
      {
        tiles.map((t) => (
          <div
            class="aspect-[4/3] overflow-hidden rounded-[18px]"
            style="border:0.5px solid var(--pd-hairline);"
          >
            <Media tone={t.tone} label={t.label} sub={t.sub} />
          </div>
        ))
      }
    </div>
  </div>
</AppShell>
