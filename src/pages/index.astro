---
export const prerender = false;
import AppShell from "../layouts/AppShell.astro";
import HomeHero from "../components/home/HomeHero.astro";
import RailHead from "../components/ui/RailHead.astro";
import QuickLaunch from "../components/home/QuickLaunch.astro";
import CardRail from "../components/home/CardRail.astro";
import FeatureBanner from "../components/home/FeatureBanner.astro";
import { listTemplates, templateToRail } from "../lib/templates";

const db = Astro.locals.runtime.env.DB;
const [trending, presets, beauty] = await Promise.all([
  listTemplates(db, { featured: true, limit: 8 }),
  listTemplates(db, { kind: "preset", limit: 8 }),
  listTemplates(db, { kind: "beauty", limit: 8 }),
]);
const trendingCards = trending.map(templateToRail);
const presetCards = presets.map(templateToRail);
const beautyCards = beauty.map(templateToRail);
---

<AppShell title="PixieDust — Home" credits={Astro.locals.user?.credits ?? 47}>
  <div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
    <HomeHero />

    <section class="mb-9">
      <RailHead title="Start a project" sub="Pick a tool" accent="var(--pd-teal)" />
      <QuickLaunch />
    </section>

    <section class="mb-9">
      <RailHead title="Trending this week" sub="Most-used · mixed" accent="var(--pd-pink)" seeAllHref="/trending" />
      <CardRail items={trendingCards} />
    </section>

    <section class="mb-9">
      <RailHead title="Main character energy" sub="Cinematic · Movie Studio" accent="var(--pd-mint)" />
      <FeatureBanner
        tone="dusk"
        kicker="Featured · Movie Studio"
        title={"Put yourself in\nthe action scene."}
        sub="4 presets · 8 cr each · Kling Pro"
        ctaLabel="Open Movie Studio"
        accent="var(--pd-mint)"
        href="/video"
        height={260}
      />
    </section>

    <section class="mb-9">
      <RailHead title="Presets" sub="Film · era · creative · pro" accent="var(--pd-amber)" seeAllHref="/presets" />
      <CardRail items={presetCards} height={260} width={180} />
    </section>

    <section class="mb-9 grid grid-cols-1 gap-3.5 md:grid-cols-2">
      <FeatureBanner
        tone="pink"
        kicker="New tool"
        title={"Fashion\nTry-on"}
        sub="Upload · wear · save"
        ctaLabel="Open"
        accent="var(--pd-pink)"
        href="/fashion"
        height={220}
      />
      <FeatureBanner
        tone="teal"
        kicker="Photoshoots"
        title={"Editorial Noir\n24 frames."}
        sub="$4.99 · 30 cr"
        ctaLabel="Run pack"
        accent="var(--pd-teal)"
        href="/shoots"
        height={220}
      />
    </section>

    <section>
      <RailHead title="Beauty Studio" sub="Try a look · 1 cr each" accent="var(--pd-mint)" seeAllHref="/beauty" />
      <CardRail items={beautyCards} height={220} width={170} />
    </section>
  </div>
</AppShell>
