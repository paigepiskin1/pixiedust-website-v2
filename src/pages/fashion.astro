---
export const prerender = false;
import AppShell from "../layouts/AppShell.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import FilterableCatalog from "../components/catalog/FilterableCatalog.astro";
import { listTemplates, templateToCard } from "../lib/templates";

const db = Astro.locals.runtime.env.DB;
const items = (await listTemplates(db, { kind: "fashion" })).map(templateToCard);
---

<AppShell title="Virtual AI Fashion Try-on — PixieDust" description="See how any outfit looks on you with AI. Virtual try-on for clothes, accessories, and full looks — no fitting room needed." credits={Astro.locals.user?.credits ?? 47}>
  <div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
    <PageHeader
      kicker="Wear anything · 2 cr"
      title="Fashion Try-on"
      sub="Upload a photo, upload a garment — or pick a look. We'll dress you in seconds."
    />
    <FilterableCatalog items={items} aspect="9 / 13" />
  </div>
</AppShell>
