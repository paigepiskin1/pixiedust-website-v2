---
export const prerender = false;
import AppShell from "../layouts/AppShell.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import Pill from "../components/ui/Pill.astro";
import CreditChip from "../components/ui/CreditChip.astro";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/auth/sign-in?redirect=/account");

const displayName = user.name || (user.email ? user.email.split("@")[0] : "You");
const initial = (displayName[0] || "U").toUpperCase();
---

<AppShell title="Account — PixieDust" credits={user.credits}>
  <div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
    <PageHeader kicker="Your account" title={displayName} sub={user.email ?? undefined} />

    <div class="grid max-w-3xl gap-4">
      <div class="flex items-center gap-4 rounded-2xl" style="padding:20px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);">
        <div
          class="flex size-14 shrink-0 items-center justify-center rounded-full font-display font-semibold text-white"
          style="background:linear-gradient(135deg, var(--pd-lilac), var(--pd-pink));font-size:22px;"
        >
          {initial}
        </div>
        <div class="min-w-0 flex-1">
          <div class="font-display font-medium text-ink" style="font-size:18px;letter-spacing:-0.3px;">{displayName}</div>
          <div class="text-ink-3" style="font-size:13px;">{user.email}</div>
        </div>
        <div class="flex items-center gap-2">
          {user.isAdmin && <Pill color="var(--pd-lilac)" label="Admin" />}
          <CreditChip cr={user.credits} size="md" />
        </div>
      </div>

      <div class="rounded-2xl" style="padding:20px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);">
        <div class="mb-2 font-mono uppercase" style="font-size:10px;color:var(--pd-ink3);letter-spacing:0.7px;">Plan</div>
        <div class="flex items-center justify-between gap-4">
          <div>
            <div class="font-semibold text-ink" style="font-size:14.5px;">Free</div>
            <div class="text-ink-3" style="font-size:12.5px;">Buy credit packs anytime. Subscriptions land in a later phase.</div>
          </div>
          <a href="/credits" class="shrink-0 rounded-xl font-bold" style="padding:10px 18px;background:var(--pd-lilac);color:#0A0A0B;font-size:13px;">Get credits</a>
        </div>
      </div>

      <div class="rounded-2xl" style="padding:20px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);">
        <div class="mb-1 font-mono uppercase" style="font-size:10px;color:var(--pd-ink3);letter-spacing:0.7px;">Session</div>
        <p class="mb-3 text-ink-3" style="font-size:12.5px;line-height:1.5;">
          The full account experience (profile, billing, notifications, privacy) arrives in Phase 7.
        </p>
        <button
          type="button"
          id="pd-signout"
          class="rounded-xl font-semibold text-ink"
          style="padding:10px 18px;background:transparent;border:0.5px solid var(--pd-hairline2);font-size:13px;cursor:pointer;"
        >
          Sign out
        </button>
      </div>
    </div>
  </div>

  <script>
    import { firebaseSignOut } from "../lib/firebase-client";
    document.getElementById("pd-signout")?.addEventListener("click", async () => {
      try {
        await fetch("/api/auth/signout", { method: "POST" });
        await firebaseSignOut();
      } catch {}
      window.location.href = "/";
    });
  </script>
</AppShell>
