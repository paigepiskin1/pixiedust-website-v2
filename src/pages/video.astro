---
export const prerender = false;
import AppShell from "../layouts/AppShell.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import FilterableCatalog from "../components/catalog/FilterableCatalog.astro";
import { listTemplates, templateToCard } from "../lib/templates";
import { VIDEO_CATS } from "../lib/catalog";

const db = Astro.locals.runtime.env.DB;
const items = (await listTemplates(db, { kinds: ["cinema", "i2v", "fashion-video", "game-video"] })).map(templateToCard);
---

<AppShell title="Video — PixieDust" credits={Astro.locals.user?.credits ?? 47}>
  <div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
    <PageHeader
      kicker="Kling 3.0 · Seedance 2.0 · Veo"
      title="Video"
      sub="Cinematic scenes, photo-to-life, fashion runway, video-game openings — drop yourself into the frame."
    />
    <FilterableCatalog items={items} categories={VIDEO_CATS} aspect="9 / 14" />
  </div>
</AppShell>
