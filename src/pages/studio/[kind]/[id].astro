---
// Workspace stub — the real 3-column generation screen lands in Phase 6.
// Server-rendered so any /studio/<kind>/<id> link resolves without prebuilt paths.
export const prerender = false;
import AppShell from "../../../layouts/AppShell.astro";
import Pill from "../../../components/ui/Pill.astro";

const { kind, id } = Astro.params;
---

<AppShell title="Workspace — PixieDust">
  <div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
    <Pill color="var(--pd-lilac)" label={`Workspace · ${kind}`} />
    <h1 class="mt-4 font-display font-medium text-ink" style="font-size:38px;letter-spacing:-1px;line-height:1.05;">
      {id}
    </h1>
    <p class="mt-2 text-ink-3" style="font-size:14.5px;max-width:540px;line-height:1.45;">
      The 3-column generation workspace (template card · inputs · output canvas) is built in
      Phase 6, wired to SyncNode. This stub keeps template links resolving in the meantime.
    </p>
    <a
      href="/"
      class="mt-6 inline-flex items-center gap-2 rounded-full font-medium text-ink"
      style="padding:8px 16px;border:0.5px solid var(--pd-hairline2);font-size:13px;"
    >
      ← Back to home
    </a>
  </div>
</AppShell>
