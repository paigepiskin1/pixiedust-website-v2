---
// Template detail / workspace. The full 3-column generation UI is built in
// Phase 6; this loads the real template from D1 and previews its config.
export const prerender = false;
import AppShell from "../../layouts/AppShell.astro";
import Pill from "../../components/ui/Pill.astro";
import Media from "../../components/ui/Media.astro";
import CreditChip from "../../components/ui/CreditChip.astro";
import { getTemplate, allFields, computeCost } from "../../lib/templates";

const { id } = Astro.params;
const db = Astro.locals.runtime.env.DB;
const template = id ? await getTemplate(db, id) : null;

if (!template) {
  return new Response(null, { status: 404, headers: { Location: "/" } });
}

const fields = allFields(template);
const baseCost = computeCost(template, { quantity: 1 });
const accent = template.accent ?? "var(--pd-lilac)";
---

<AppShell title={`${template.title} — PixieDust`} credits={Astro.locals.user?.credits ?? 47}>
  <div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px]">
      <!-- preview -->
      <div class="overflow-hidden rounded-[24px]" style="border:0.5px solid var(--pd-hairline);aspect-ratio:16/10;">
        <Media tone={template.tone} angle={130} label={template.title} sub={template.engine ?? undefined} />
      </div>

      <!-- template card -->
      <div class="flex flex-col gap-4">
        <div>
          <div class="mb-2 flex items-center gap-2">
            <Pill color={accent} label={template.kind} />
            {template.type === "video" && <Pill color="var(--pd-pink)" label="Video" />}
          </div>
          <h1 class="font-display font-medium text-ink" style="font-size:30px;letter-spacing:-0.7px;line-height:1.05;">
            {template.title}
          </h1>
          {template.description && <p class="mt-2 text-ink-3" style="font-size:13.5px;line-height:1.5;">{template.description}</p>}
        </div>

        <div class="flex flex-wrap items-center gap-2">
          <CreditChip cr={baseCost} size="md" />
          {template.engine && <span class="font-mono uppercase" style="font-size:10px;color:var(--pd-ink3);letter-spacing:0.6px;">{template.engine}</span>}
          {template.eta && <span class="font-mono uppercase" style="font-size:10px;color:var(--pd-ink3);letter-spacing:0.6px;">· {template.eta}</span>}
        </div>

        <div class="rounded-2xl" style="padding:16px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);">
          <div class="mb-2 font-mono uppercase" style="font-size:10px;color:var(--pd-ink3);letter-spacing:0.7px;">
            Inputs {template.steps ? `· ${template.steps.length} steps` : ""}
          </div>
          <ul class="flex flex-col gap-2">
            {
              fields.map((f) => (
                <li class="flex items-center justify-between gap-3">
                  <span class="text-ink" style="font-size:13px;">{f.label}{f.required ? " *" : ""}</span>
                  <span class="font-mono uppercase" style="font-size:9.5px;color:var(--pd-ink3);letter-spacing:0.5px;">{f.type}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="rounded-xl" style="padding:12px 14px;background:color-mix(in srgb, var(--pd-lilac) 10%, transparent);border:0.5px solid color-mix(in srgb, var(--pd-lilac) 30%, transparent);">
          <span class="text-ink-2" style="font-size:12.5px;">The full generation workspace (live inputs + output canvas, wired to SyncNode) lands in Phase 6.</span>
        </div>
      </div>
    </div>
  </div>
</AppShell>
