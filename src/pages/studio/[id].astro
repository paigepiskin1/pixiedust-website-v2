---
// The 3-column generation workspace, wired to /api/generate + SyncNode.
export const prerender = false;
import AppShell from "../../layouts/AppShell.astro";
import Pill from "../../components/ui/Pill.astro";
import Media from "../../components/ui/Media.astro";
import CreditChip from "../../components/ui/CreditChip.astro";
import { getTemplate, allFields, computeCost } from "../../lib/templates";

const { id } = Astro.params;
const db = Astro.locals.runtime.env.DB;
const template = id ? await getTemplate(db, id) : null;
if (!template) return new Response(null, { status: 302, headers: { Location: "/" } });

const fields = allFields(template);
const accent = template.accent ?? "var(--pd-lilac)";
const credits = Astro.locals.user?.credits ?? 0;
const signedIn = !!Astro.locals.user;
const baseCost = computeCost(template, { quantity: template.quantities?.[0] ?? 1, duration: template.durations?.[0] });
const qualityKeys = template.quality ? Object.keys(template.quality) : [];
const qualityLabels: Record<string, string> = { std: "Standard", pro: "Pro", cinema: "Cinema" };

const config = {
  id: template.id,
  type: template.type,
  creditCost: template.creditCost,
  pricePerSecond: template.pricePerSecond,
  durations: template.durations,
  quality: template.quality,
  credits,
  signedIn,
};
---

<AppShell title={`${template.title} — PixieDust`} credits={credits}>
  <div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
    <div class="grid gap-6 lg:grid-cols-[300px_minmax(0,1fr)_minmax(0,1fr)]">
      <!-- LEFT: template card -->
      <aside class="lg:sticky lg:top-[88px] lg:self-start">
        <div class="overflow-hidden rounded-[20px]" style="border:0.5px solid var(--pd-hairline);aspect-ratio:4/3;background:var(--pd-bg2);">
          {
            template.previewVideo ? (
              <video src={template.previewVideo} muted loop autoplay playsinline class="h-full w-full object-cover" />
            ) : template.previewImage ? (
              <img src={template.previewImage} alt={template.title} class="h-full w-full object-cover" />
            ) : (
              <Media tone={template.tone} angle={130} label={template.title} sub={template.engine ?? undefined} />
            )
          }
        </div>
        <div class="mt-3 flex items-center gap-2">
          <Pill color={accent} label={template.kind} />
          {template.type === "video" && <Pill color="var(--pd-pink)" label="Video" />}
        </div>
        <h1 class="mt-2 font-display font-medium text-ink" style="font-size:24px;letter-spacing:-0.5px;line-height:1.1;">{template.title}</h1>
        {template.subtitle && <div class="mt-1 text-ink-3" style="font-size:12.5px;">{template.subtitle}</div>}
        {template.description && <p class="mt-2 text-ink-2" style="font-size:13px;line-height:1.5;">{template.description}</p>}
        <div class="mt-4 grid grid-cols-2 gap-2">
          {[["Engine", template.engine], ["ETA", template.eta], ["Cost", `${template.creditCost} cr`], ["Type", template.type]].filter(([, v]) => v).map(([k, v]) => (
            <div class="rounded-xl" style="padding:10px 12px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);">
              <div class="font-mono uppercase" style="font-size:9px;color:var(--pd-ink4);letter-spacing:0.6px;">{k}</div>
              <div class="mt-0.5 font-semibold text-ink" style="font-size:12.5px;">{v}</div>
            </div>
          ))}
        </div>
      </aside>

      <!-- CENTER: inputs -->
      <section class="lg:sticky lg:top-[88px] lg:self-start">
        <div class="rounded-2xl" style="padding:20px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);">
          <div class="mb-3 font-mono uppercase" style="font-size:10px;color:var(--pd-ink3);letter-spacing:0.7px;">Your inputs</div>

          <div class="flex flex-col gap-4">
            {fields.map((f) => (
              <label class="block">
                <span class="mb-1.5 block font-medium text-ink" style="font-size:12.5px;">{f.label}{f.required ? " *" : ""}</span>
                {f.type === "textarea" ? (
                  <textarea data-field={f.key} rows="3" placeholder={f.placeholder} class="w-full rounded-xl text-ink outline-none" style="padding:11px 13px;background:var(--pd-bg);border:0.5px solid var(--pd-hairline2);font-size:13.5px;line-height:1.5;resize:vertical;">{String(f.default ?? "")}</textarea>
                ) : f.type === "select" ? (
                  <select data-field={f.key} class="w-full rounded-xl text-ink outline-none" style="padding:11px 13px;background:var(--pd-bg);border:0.5px solid var(--pd-hairline2);font-size:13.5px;">
                    {(f.options ?? []).map((o) => <option value={o.value} selected={o.value === f.default}>{o.label}</option>)}
                  </select>
                ) : f.type === "number" ? (
                  <input data-field={f.key} type="number" min={f.min} max={f.max} step={f.step} value={f.default as number | undefined} class="w-full rounded-xl text-ink outline-none" style="padding:11px 13px;background:var(--pd-bg);border:0.5px solid var(--pd-hairline2);font-size:13.5px;" />
                ) : f.type === "file" ? (
                  <div class="pd-file-wrap" data-fieldkey={f.key}>
                    <label class="pd-upload-zone relative flex w-full cursor-pointer flex-col items-center gap-1.5 rounded-xl text-center" style="padding:18px 14px;background:var(--pd-bg);border:1px dashed var(--pd-hairline2);transition:border-color 0.15s;">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="var(--pd-ink3)" stroke-width="1.4" stroke-linecap="round"><path d="M10 13V7M7 10l3-3 3 3"/><rect x="3" y="3" width="14" height="14" rx="3"/></svg>
                      <span style="font-size:12px;color:var(--pd-ink3);">Click to upload</span>
                      <input data-field={f.key} type="file" accept={f.accept} class="absolute inset-0 cursor-pointer opacity-0" style="z-index:1;" />
                    </label>
                    <div class="pd-file-preview hidden overflow-hidden rounded-xl" style="background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);">
                      <img class="pd-preview-img block w-full" style="max-height:160px;object-fit:cover;" alt="" />
                      <div class="flex items-center justify-between gap-2" style="padding:7px 10px;border-top:0.5px solid var(--pd-hairline);">
                        <span class="pd-preview-status truncate" style="font-size:11px;color:var(--pd-ink3);"></span>
                        <button type="button" class="pd-file-clear flex shrink-0 size-5 items-center justify-center rounded-full" style="background:var(--pd-bg3);border:0.5px solid var(--pd-hairline2);color:var(--pd-ink3);font-size:10px;cursor:pointer;" aria-label="Remove">✕</button>
                      </div>
                    </div>
                  </div>
                ) : (
                  <input data-field={f.key} type={f.type === "url" ? "url" : f.type === "email" ? "email" : "text"} placeholder={f.placeholder} value={String(f.default ?? "")} class="w-full rounded-xl text-ink outline-none" style="padding:11px 13px;background:var(--pd-bg);border:0.5px solid var(--pd-hairline2);font-size:13.5px;" />
                )}
                {f.help && <span class="mt-1 block text-ink-4" style="font-size:11px;">{f.help}</span>}
              </label>
            ))}

            {template.aspects && template.aspects.length > 0 && (
              <div>
                <span class="mb-1.5 block font-medium text-ink" style="font-size:12.5px;">Aspect ratio</span>
                <div class="flex flex-wrap gap-1.5" data-controls="aspect">
                  {template.aspects.map((a, i) => (
                    <button type="button" class="pd-seg rounded-lg font-mono" data-val={a} data-active={i === 0 ? "true" : "false"} style="padding:7px 12px;font-size:11px;cursor:pointer;">{a}</button>
                  ))}
                </div>
              </div>
            )}

            {template.durations && template.durations.length > 0 && (
              <div>
                <span class="mb-1.5 block font-medium text-ink" style="font-size:12.5px;">Duration{template.pricePerSecond ? ` · ${template.pricePerSecond} cr/sec` : ""}</span>
                <div class="flex flex-wrap gap-1.5" data-controls="duration">
                  {template.durations.map((d, i) => (
                    <button type="button" class="pd-seg rounded-lg font-semibold" data-val={d} data-active={i === 0 ? "true" : "false"} style="padding:7px 14px;font-size:12px;cursor:pointer;">{d}s</button>
                  ))}
                </div>
              </div>
            )}

            {qualityKeys.length > 1 && (
              <div>
                <span class="mb-1.5 block font-medium text-ink" style="font-size:12.5px;">Quality</span>
                <div class="flex flex-wrap gap-1.5" data-controls="quality">
                  {qualityKeys.map((q, i) => (
                    <button type="button" class="pd-seg rounded-lg font-semibold" data-val={q} data-mult={template.quality![q]} data-active={i === 0 ? "true" : "false"} style="padding:7px 12px;font-size:11.5px;cursor:pointer;">{qualityLabels[q] ?? q}</button>
                  ))}
                </div>
              </div>
            )}

            <div>
              <span class="mb-1.5 block font-medium text-ink" style="font-size:12.5px;">Outputs <span class="text-ink-3" style="font-weight:400;">· generated in parallel</span></span>
              <div class="flex flex-wrap gap-1.5" data-controls="quantity">
                {(template.quantities && template.quantities.length > 1 ? template.quantities : template.type === "video" ? [1, 2] : [1, 2, 3, 4]).map((n, i) => (
                  <button type="button" class="pd-seg rounded-lg font-semibold" data-val={n} data-active={i === 0 ? "true" : "false"} style="padding:7px 14px;font-size:12px;cursor:pointer;">{n}</button>
                ))}
              </div>
            </div>
          </div>

          <div id="pd-gen-error" class="mt-3 hidden rounded-lg" style="padding:9px 12px;background:color-mix(in srgb, var(--pd-pink) 12%, transparent);border:0.5px solid color-mix(in srgb, var(--pd-pink) 40%, transparent);color:var(--pd-pink);font-size:12.5px;"></div>

          <button id="pd-generate" type="button" class="mt-4 flex w-full items-center justify-center gap-2 rounded-xl font-bold" style="padding:13px 16px;background:var(--pd-lilac);color:#0A0A0B;font-size:14px;letter-spacing:-0.1px;cursor:pointer;">
            <span id="pd-gen-label">Generate · {baseCost} cr</span>
          </button>
          <div class="mt-2 text-center font-mono uppercase" style="font-size:9.5px;color:var(--pd-ink4);letter-spacing:0.5px;">
            {template.engine ?? "SyncNode"} · {template.eta ?? "async"}
          </div>
        </div>
      </section>

      <!-- RIGHT: output canvas — async jobs feed (each Generate adds a tile) -->
      <section>
        <div id="pd-output" class="relative overflow-hidden rounded-[20px]" style="min-height:420px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);">
          <div id="pd-out-empty" class="absolute inset-0 flex flex-col items-center justify-center px-8 text-center">
            <div class="mx-auto mb-3 flex size-12 items-center justify-center rounded-full" style="background:var(--pd-bg3);border:0.5px solid var(--pd-hairline2);">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="var(--pd-ink3)" stroke-width="1.4" stroke-linecap="round"><path d="M10 3v3M10 14v3M3 10h3M14 10h3M5 5l2 2M13 13l2 2M15 5l-2 2M5 15l2-2" /></svg>
            </div>
            <div class="text-ink-3" style="font-size:13px;">Your results appear here. Run as many as you like — they generate in parallel.</div>
          </div>
          <!-- Job tiles get prepended here; newest first. -->
          <div id="pd-jobs" class="grid gap-3" style="padding:14px;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));"></div>
        </div>
      </section>
    </div>
  </div>

  <script type="application/json" id="pd-config" is:inline set:html={JSON.stringify(config)}></script>

  <style>
    .pd-seg { background: var(--pd-bg); color: var(--pd-ink-2, var(--pd-ink2)); border: 0.5px solid var(--pd-hairline2); }
    .pd-seg[data-active="true"] { background: var(--pd-ink); color: var(--pd-bg); border-color: transparent; }
    @keyframes pd-spin { to { transform: rotate(360deg); } }
  </style>

  <script>
    const cfg = JSON.parse(document.getElementById("pd-config")!.textContent || "{}");
    const root = document;
    const $ = <T extends HTMLElement = HTMLElement>(s: string) => root.querySelector<T>(s)!;

    let credits: number = Number(cfg.credits) || 0;

    function controlValue(group: string): string | null {
      const wrap = root.querySelector(`[data-controls="${group}"]`);
      if (!wrap) return null;
      const active = wrap.querySelector<HTMLElement>('.pd-seg[data-active="true"]');
      return active?.dataset.val ?? null;
    }
    function qualityMult(): number {
      const q = controlValue("quality");
      if (q && cfg.quality && cfg.quality[q]) return Number(cfg.quality[q]);
      return 1;
    }
    function quantity(): number {
      return Number(controlValue("quantity")) || 1;
    }
    function duration(): number {
      return Number(controlValue("duration")) || (cfg.durations && cfg.durations[0]) || 0;
    }
    function unitCost(): number {
      const base = cfg.pricePerSecond && duration() ? Number(cfg.pricePerSecond) * duration() : Number(cfg.creditCost);
      return Math.ceil(base * qualityMult());
    }
    function cost(): number {
      // Total for the button: one charge per parallel output.
      return unitCost() * quantity();
    }

    const genBtn = $("#pd-generate") as HTMLButtonElement;
    const genLabel = $("#pd-gen-label");
    function refreshButton() {
      const c = cost();
      if (!cfg.signedIn) {
        genLabel.textContent = "Sign in to generate";
        return;
      }
      if (credits < c) {
        genLabel.textContent = `Get more credits · need ${c} cr`;
        genBtn.style.background = "transparent";
        genBtn.style.color = "var(--pd-ink)";
        genBtn.style.border = "0.5px solid var(--pd-hairline2)";
      } else {
        genLabel.textContent = `Generate · ${c} cr`;
        genBtn.style.background = "var(--pd-lilac)";
        genBtn.style.color = "#0A0A0B";
        genBtn.style.border = "none";
      }
    }

    // segmented controls
    root.querySelectorAll<HTMLElement>("[data-controls]").forEach((wrap) => {
      wrap.querySelectorAll<HTMLElement>(".pd-seg").forEach((btn) => {
        btn.addEventListener("click", () => {
          wrap.querySelectorAll<HTMLElement>(".pd-seg").forEach((b) => b.setAttribute("data-active", String(b === btn)));
          refreshButton();
        });
      });
    });

    const fileUrls: Record<string, string> = {};
    let uploading = 0;

    // Upload file fields to Bunny on selection; store the public URL.
    root.querySelectorAll<HTMLInputElement>('input[type="file"][data-field]').forEach((el) => {
      const key = el.dataset.field!;
      const wrap = el.closest(".pd-file-wrap") as HTMLElement | null;
      const zone = wrap?.querySelector(".pd-upload-zone") as HTMLElement | null;
      const preview = wrap?.querySelector(".pd-file-preview") as HTMLElement | null;
      const previewImg = wrap?.querySelector(".pd-preview-img") as HTMLImageElement | null;
      const status = wrap?.querySelector(".pd-preview-status") as HTMLElement | null;
      const clearBtn = wrap?.querySelector(".pd-file-clear") as HTMLElement | null;

      el.addEventListener("change", async () => {
        const file = el.files?.[0];
        if (!file) return;

        // Show immediate local preview
        const localUrl = URL.createObjectURL(file);
        if (previewImg) previewImg.src = localUrl;
        zone?.classList.add("hidden");
        preview?.classList.remove("hidden");
        if (status) { status.textContent = "Uploading…"; status.style.color = "var(--pd-ink3)"; }

        uploading++;
        const fd = new FormData();
        fd.append("file", file);
        try {
          const r = await fetch("/api/upload", { method: "POST", body: fd });
          const d = await r.json();
          if (r.ok) {
            fileUrls[key] = d.url;
            if (previewImg) previewImg.src = d.url;
            URL.revokeObjectURL(localUrl);
            if (status) { status.textContent = "✓ Uploaded"; status.style.color = "var(--pd-mint)"; }
          } else {
            if (status) { status.textContent = d.error || "Upload failed"; status.style.color = "var(--pd-pink)"; }
            delete fileUrls[key];
          }
        } catch {
          if (status) { status.textContent = "Upload failed"; status.style.color = "var(--pd-pink)"; }
          delete fileUrls[key];
        } finally {
          uploading--;
        }
      });

      clearBtn?.addEventListener("click", () => {
        delete fileUrls[key];
        el.value = "";
        if (previewImg) previewImg.src = "";
        preview?.classList.add("hidden");
        zone?.classList.remove("hidden");
      });
    });

    function collectInputs(): Record<string, unknown> {
      const out: Record<string, unknown> = {};
      root.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>("[data-field]").forEach((el) => {
        if ((el as HTMLInputElement).type === "file") {
          if (fileUrls[el.dataset.field!]) out[el.dataset.field!] = fileUrls[el.dataset.field!];
          return;
        }
        out[el.dataset.field!] = el.value;
      });
      return out;
    }

    const errEl = $("#pd-gen-error");
    const emptyEl = $("#pd-out-empty");
    const jobsEl = $("#pd-jobs");
    const isVideo = cfg.type === "video";

    function showError(msg: string) {
      errEl.textContent = msg;
      errEl.classList.remove("hidden");
    }

    // Humanize provider errors and make clear the user wasn't charged. Most
    // failures (e.g. the model's safety filter) aren't the user's fault.
    function friendlyError(raw: unknown): string {
      const e = String(raw ?? "").replace(/\s*\(refunded\)\s*$/i, "");
      if (/e005|flagged as sensitive|safety|moderation|content policy|nsfw|sensitive/i.test(e))
        return "The model's safety filter blocked this — it often triggers on real faces or sensitive content. You weren't charged; try a different photo or prompt.";
      if (/rate limit|slow down/i.test(e)) return "Too many requests right now. You weren't charged — try again in a minute.";
      if (/timeout|timed out/i.test(e)) return "This took too long and timed out. You weren't charged — try again.";
      if (/not enough credits/i.test(e)) return "Not enough credits.";
      return (e || "Generation failed") + " — you weren't charged.";
    }

    // Each Generate click spawns an independent job tile that polls on its own,
    // so users can queue many generations in parallel (async). The button is
    // never disabled.
    function createTile(): HTMLElement {
      emptyEl.classList.add("hidden");
      const tile = document.createElement("div");
      tile.className = "pd-job";
      tile.style.cssText = "position:relative;aspect-ratio:1/1.1;border-radius:14px;overflow:hidden;background:var(--pd-bg3);border:0.5px solid var(--pd-hairline2);";
      tile.innerHTML =
        '<div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding:14px;text-align:center;">' +
        '<div style="width:30px;height:30px;border-radius:50%;border:3px solid var(--pd-hairline2);border-top-color:var(--pd-lilac);animation:pd-spin .8s linear infinite;"></div>' +
        '<div class="pd-job-stage font-mono uppercase" style="font-size:9.5px;letter-spacing:.7px;color:var(--pd-ink2);">Submitting…</div>' +
        '<div style="height:4px;width:80%;background:var(--pd-hairline2);border-radius:999px;overflow:hidden;"><div class="pd-job-bar" style="height:100%;width:8%;background:var(--pd-lilac);transition:width .5s;"></div></div>' +
        "</div>";
      jobsEl.prepend(tile);
      return tile;
    }

    function tileStage(tile: HTMLElement, text: string, pct: number) {
      const s = tile.querySelector<HTMLElement>(".pd-job-stage");
      if (s) s.textContent = text;
      const b = tile.querySelector<HTMLElement>(".pd-job-bar");
      if (b) b.style.width = pct + "%";
    }

    function tileFail(tile: HTMLElement, msg: string) {
      tile.innerHTML =
        '<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;padding:14px;text-align:center;color:var(--pd-pink);font-size:11.5px;line-height:1.4;"></div>';
      (tile.firstElementChild as HTMLElement).textContent = msg;
    }

    function tileResult(tile: HTMLElement, outputs: string[]) {
      tile.innerHTML = "";
      const wrap = document.createElement("div");
      wrap.style.cssText = `display:grid;gap:4px;width:100%;height:100%;grid-template-columns:repeat(${outputs.length > 1 ? 2 : 1},1fr);`;
      outputs.forEach((url) => {
        const el = isVideo ? document.createElement("video") : document.createElement("img");
        el.src = url;
        if (isVideo) {
          const v = el as HTMLVideoElement;
          v.controls = true;
          v.playsInline = true;
          v.muted = true;
          v.loop = true;
          v.autoplay = true;
        }
        el.style.cssText = "width:100%;height:100%;object-fit:cover;";
        wrap.appendChild(el);
      });
      tile.appendChild(wrap);
      if (outputs[0]) {
        const dl = document.createElement("a");
        dl.href = outputs[0];
        dl.setAttribute("download", "");
        dl.textContent = "Download";
        dl.style.cssText = "position:absolute;right:8px;bottom:8px;padding:5px 10px;border-radius:8px;background:rgba(10,10,11,.72);backdrop-filter:blur(8px);color:#fff;font-size:10.5px;text-decoration:none;";
        tile.appendChild(dl);
      }
    }

    async function poll(id: string, tile: HTMLElement): Promise<void> {
      const stages = ["Reading your inputs", "Running the model", "Refining", "Almost there"];
      let tick = 0;
      while (true) {
        await new Promise((r) => setTimeout(r, 2000));
        tick++;
        let data: any;
        try {
          data = await (await fetch(`/api/generate/status?id=${id}`)).json();
        } catch {
          continue; // transient; keep polling
        }
        if (data.steps > 1 && data.step) tileStage(tile, `Step ${data.step}/${data.steps}…`, Math.min(12 + tick * 10, 92));
        else tileStage(tile, stages[Math.min(tick, stages.length - 1)] + "…", Math.min(12 + tick * 14, 92));
        if (data.status === "completed") {
          tileResult(tile, data.outputs || []);
          return;
        }
        if (data.status === "failed") {
          credits += cost(); // refunded
          refreshButton();
          tileFail(tile, friendlyError(data.error));
          return;
        }
      }
    }

    // One independent job per output (each charged the unit cost), so any
    // template can produce several in parallel.
    async function launchJob(inputs: Record<string, unknown>, per: number) {
      const tile = createTile();
      credits -= per; // optimistic debit
      refreshButton();
      try {
        const res = await fetch("/api/generate", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            templateId: cfg.id,
            inputs,
            quality: controlValue("quality") || undefined,
            quantity: 1,
            aspect: controlValue("aspect") || undefined,
            duration: duration() || undefined,
          }),
        });
        const data = await res.json();
        if (!res.ok) {
          credits += per;
          refreshButton();
          if (data.needCredits) {
            tileFail(tile, "Not enough credits.");
            setTimeout(() => (window.location.href = "/credits"), 900);
          } else {
            tileFail(tile, friendlyError(data.error || "Could not start generation."));
          }
          return;
        }
        await poll(data.id, tile);
      } catch (err) {
        credits += per;
        refreshButton();
        tileFail(tile, "Network error — try again.");
      }
    }

    function generate() {
      if (!cfg.signedIn) {
        window.location.href = "/auth/sign-in?redirect=" + encodeURIComponent(location.pathname);
        return;
      }
      if (uploading > 0) {
        showError("Hang on — a file is still uploading.");
        return;
      }
      if (credits < cost()) {
        window.location.href = "/credits";
        return;
      }
      errEl.classList.add("hidden");
      const n = quantity();
      const per = unitCost();
      const inputs = collectInputs(); // snapshot once for all parallel jobs
      for (let i = 0; i < n; i++) launchJob(inputs, per);
    }

    genBtn.addEventListener("click", generate);
    refreshButton();
  </script>
</AppShell>
