---
export const prerender = false;
import AppShell from "../layouts/AppShell.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import { getUserByUid } from "../lib/users";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/auth/sign-in?redirect=/gallery");

const db = Astro.locals.runtime.env.DB;
const dbUser = await getUserByUid(db, user.uid);

interface Row {
  id: string; type: string; kind: string; output_url: string;
  template_id: string | null; created: string; template_title: string | null;
  input_json: string | null;
}
const { results } = await db
  .prepare(
    `SELECT g.id, g.type, g.kind, g.output_url, g.template_id,
            datetime(g.created_at) AS created, t.title AS template_title, g.input_json
     FROM generations g LEFT JOIN templates t ON t.id = g.template_id
     WHERE g.user_id = ? AND g.status = 'completed' AND g.output_url IS NOT NULL
     ORDER BY g.created_at DESC`
  )
  .bind(dbUser!.id)
  .all<Row>();

function extractPrompt(j: string | null): string | null {
  if (!j) return null;
  try { const o = JSON.parse(j); return o.prompt ?? o.caption ?? o.text ?? null; } catch { return null; }
}

interface Item {
  id: string; idx: number; type: string; kind: string; output_url: string;
  template_id: string | null; created: string; template_title: string | null;
  prompt: string | null;
}
const items: Item[] = (results ?? []).map((r, i) => ({
  id: r.id, idx: i, type: r.type, kind: r.kind, output_url: r.output_url,
  template_id: r.template_id, created: r.created, template_title: r.template_title,
  prompt: extractPrompt(r.input_json),
}));

const todayStr = new Date().toISOString().slice(0, 10);
const yestStr = new Date(Date.now() - 86400000).toISOString().slice(0, 10);
function dayLabel(day: string) {
  if (day === todayStr) return "Today";
  if (day === yestStr) return "Yesterday";
  return new Date(day + "T12:00:00Z").toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
}
const dayMap = new Map<string, Item[]>();
for (const it of items) {
  const d = it.created.slice(0, 10);
  if (!dayMap.has(d)) dayMap.set(d, []);
  dayMap.get(d)!.push(it);
}
const dayGroups = [...dayMap.entries()].map(([d, its]) => ({ label: dayLabel(d), day: d, items: its }));
const tabs = ["All", "Images", "Video"];
---

<AppShell title="My creations — PixieDust" credits={user.credits}>
  <div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
    <PageHeader
      kicker={`${items.length} creation${items.length === 1 ? "" : "s"}`}
      title="My creations"
      sub="Everything you've made. Click any to pop it out — download, share, remix, or delete."
    >
      <a slot="right" href="/" class="shrink-0 rounded-xl font-bold" style="padding:10px 18px;background:var(--pd-lilac);color:#0A0A0B;font-size:13px;">+ New project</a>
    </PageHeader>

    {items.length === 0 ? (
      <div class="flex flex-col items-center justify-center rounded-2xl text-center" style="padding:64px 24px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);">
        <div class="mb-3 flex size-12 items-center justify-center rounded-full" style="background:var(--pd-bg3);border:0.5px solid var(--pd-hairline2);">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="var(--pd-ink3)" stroke-width="1.4"><rect x="3" y="3" width="6" height="6" rx="1" /><rect x="11" y="3" width="6" height="6" rx="1" /><rect x="3" y="11" width="6" height="6" rx="1" /><rect x="11" y="11" width="6" height="6" rx="1" /></svg>
        </div>
        <div class="font-display font-medium text-ink" style="font-size:20px;letter-spacing:-0.4px;">Nothing here yet.</div>
        <p class="mx-auto mt-1.5 text-ink-3" style="font-size:13px;max-width:320px;">Pick a tool and make something — your creations land here automatically.</p>
        <a href="/presets" class="mt-5 rounded-xl font-bold" style="padding:11px 20px;background:var(--pd-lilac);color:#0A0A0B;font-size:13px;">Browse presets</a>
      </div>
    ) : (
      <div id="pd-gallery" data-select="false">

        <!-- Toolbar -->
        <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
          <div id="pd-tabs" class="flex flex-wrap gap-2">
            {tabs.map((t, i) => (
              <button type="button" class="pd-gtab rounded-full font-semibold" data-tab={t} data-active={i === 0 ? "true" : "false"} style="padding:8px 16px;font-size:12.5px;cursor:pointer;">{t}</button>
            ))}
          </div>
          <!-- Normal mode right -->
          <div id="pd-toolbar-normal">
            <button type="button" id="pd-select-toggle" class="rounded-xl font-semibold" style="padding:8px 16px;font-size:12.5px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);color:var(--pd-ink2);cursor:pointer;">Select</button>
          </div>
          <!-- Select mode right (hidden by default) -->
          <div id="pd-toolbar-select" class="hidden flex-wrap items-center gap-2">
            <span id="pd-sel-count" class="font-semibold text-ink" style="font-size:13px;">0 selected</span>
            <button type="button" id="pd-select-all" class="rounded-lg font-medium" style="padding:7px 13px;font-size:12px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);color:var(--pd-ink2);cursor:pointer;">Select all</button>
            <button type="button" id="pd-bulk-download" class="rounded-lg font-semibold" style="display:none;padding:7px 13px;font-size:12px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);color:var(--pd-ink);cursor:pointer;">Download</button>
            <button type="button" id="pd-bulk-delete" class="rounded-lg font-semibold" style="display:none;padding:7px 13px;font-size:12px;background:transparent;border:0.5px solid color-mix(in srgb, var(--pd-pink) 50%, transparent);color:var(--pd-pink);cursor:pointer;">Delete</button>
            <button type="button" id="pd-select-cancel" class="rounded-lg font-medium" style="padding:7px 13px;font-size:12px;background:transparent;border:0.5px solid var(--pd-hairline);color:var(--pd-ink3);cursor:pointer;">Cancel</button>
          </div>
        </div>

        <!-- Search -->
        <div class="mb-5 relative">
          <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2" width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="var(--pd-ink4)" stroke-width="1.7" stroke-linecap="round"><circle cx="5.5" cy="5.5" r="3.5"/><path d="M9 9l2.5 2.5"/></svg>
          <input id="pd-search" type="search" placeholder="Search by prompt or template…" autocomplete="off" class="w-full rounded-xl outline-none" style="padding:9px 12px 9px 32px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);font-size:12.5px;color:var(--pd-ink);" />
        </div>

        <!-- Day groups -->
        {dayGroups.map(group => (
          <div class="pd-day-group mb-8" data-day={group.day}>
            <div class="mb-3 flex items-center gap-2.5">
              <span class="font-semibold text-ink" style="font-size:14.5px;">{group.label}</span>
              <span style="font-size:12px;color:var(--pd-ink3);">{group.items.length} creation{group.items.length === 1 ? "" : "s"}</span>
            </div>
            <div class="grid grid-cols-2 gap-3.5 sm:grid-cols-3 lg:grid-cols-4">
              {group.items.map(it => (
                <button
                  type="button"
                  class="pd-gcard pd-lift group relative block overflow-hidden rounded-[18px]"
                  data-idx={it.idx}
                  data-id={it.id}
                  data-type={it.type}
                  data-selected="false"
                  style="aspect-ratio:1/1.2;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);cursor:pointer;"
                >
                  {it.type === "video" ? (
                    <video src={it.output_url} muted loop playsinline preload="metadata" class="pd-gvid pd-autoplay h-full w-full object-cover" />
                  ) : (
                    <img src={it.output_url} loading="lazy" alt={it.template_title ?? "creation"} class="h-full w-full object-cover" />
                  )}
                  <div class="absolute inset-0 opacity-0 transition-opacity group-hover:opacity-100" style="background:linear-gradient(180deg,transparent 55%,rgba(0,0,0,0.7) 100%);" />
                  <div class="absolute inset-x-3 bottom-2.5 truncate text-left font-semibold text-white opacity-0 transition-opacity group-hover:opacity-100" style="font-size:12.5px;">{it.template_title ?? it.kind}</div>
                  <!-- quick-delete (normal mode, hover) -->
                  <div
                    role="button"
                    tabindex="0"
                    class="pd-qd-btn absolute right-2 top-2 flex size-7 items-center justify-center rounded-full opacity-0 transition-opacity group-hover:opacity-100"
                    data-id={it.id}
                    aria-label="Delete"
                    style="background:rgba(15,15,18,0.65);border:0.5px solid rgba(255,255,255,0.18);color:#fff;z-index:2;cursor:pointer;backdrop-filter:blur(4px);"
                  >
                    <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M1.5 2.5h8M3.5 2.5V1.5h4v1M3.5 4.5v4M7.5 4.5v4M2.5 2.5l.5 6.5h5l.5-6.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                  <!-- select checkbox (select mode) -->
                  <div class="pd-sel-check absolute right-2 top-2 flex size-7 items-center justify-center rounded-full" style="background:rgba(15,15,18,0.55);border:1.5px solid rgba(255,255,255,0.5);transition:background 0.1s,border-color 0.1s;">
                    <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M1.5 5.5l2.5 3 5.5-6"/></svg>
                  </div>
                </button>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Lightbox -->
  <div id="pd-lb" class="fixed inset-0 z-[220] hidden items-center justify-center p-6" style="background:rgba(5,5,8,0.82);backdrop-filter:blur(14px);">
    <div class="grid w-full overflow-hidden rounded-[24px] lg:grid-cols-[minmax(0,1.4fr)_minmax(320px,0.8fr)]" style="max-width:1100px;max-height:calc(100vh - 48px);background:var(--pd-raised);border:0.5px solid var(--pd-hairline2);">
      <div class="relative flex items-center justify-center" style="background:#0a0a0b;min-height:320px;">
        <div id="pd-lb-media" class="h-full w-full"></div>
        <button type="button" id="pd-lb-prev" class="absolute left-3 top-1/2 flex size-9 -translate-y-1/2 items-center justify-center rounded-full" style="background:rgba(10,10,11,0.55);border:0.5px solid rgba(255,255,255,0.14);color:#fff;cursor:pointer;" aria-label="Previous">‹</button>
        <button type="button" id="pd-lb-next" class="absolute right-3 top-1/2 flex size-9 -translate-y-1/2 items-center justify-center rounded-full" style="background:rgba(10,10,11,0.55);border:0.5px solid rgba(255,255,255,0.14);color:#fff;cursor:pointer;" aria-label="Next">›</button>
      </div>
      <div class="flex min-h-0 flex-col overflow-y-auto">
        <div class="flex items-center justify-between gap-3" style="padding:12px 16px;border-bottom:0.5px solid var(--pd-hairline);position:sticky;top:0;z-index:2;background:var(--pd-raised);">
          <div class="min-w-0">
            <div id="pd-lb-kind" class="font-mono uppercase" style="font-size:9.5px;color:var(--pd-lilac);letter-spacing:0.8px;"></div>
            <div id="pd-lb-title" class="truncate font-display font-medium text-ink" style="font-size:15px;letter-spacing:-0.3px;"></div>
            <div id="pd-lb-meta" class="text-ink-3" style="font-size:10.5px;"></div>
          </div>
          <button type="button" id="pd-lb-close" class="flex size-7 shrink-0 items-center justify-center rounded-full" style="background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);color:var(--pd-ink2);cursor:pointer;font-size:13px;" aria-label="Close">✕</button>
        </div>
        <!-- Icon action bar -->
        <div class="flex items-center gap-1.5" style="padding:12px 16px;">
          <a id="pd-lb-download" href="#" download title="Download" class="flex size-8 shrink-0 items-center justify-center rounded-full" style="background:var(--pd-lilac);color:#0A0A0B;">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 2v7M4.5 7l2.5 2.5L9.5 7"/><path d="M2 12h10"/></svg>
          </a>
          <button type="button" id="pd-lb-share" title="Copy link" class="flex size-8 shrink-0 items-center justify-center rounded-full" style="background:var(--pd-bg2);border:0.5px solid var(--pd-hairline2);color:var(--pd-ink2);cursor:pointer;">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><circle cx="10" cy="2.5" r="1.5"/><circle cx="10" cy="10.5" r="1.5"/><circle cx="2.5" cy="6.5" r="1.5"/><path d="M4 6.5l4.5-3.5M4 6.5l4.5 3.5"/></svg>
          </button>
          <button type="button" id="pd-lb-copy-prompt" title="Copy prompt" class="flex size-8 shrink-0 items-center justify-center rounded-full" style="display:none;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline2);color:var(--pd-ink2);cursor:pointer;">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3.5" y="3.5" width="6" height="6" rx="1.2"/><path d="M1.5 8.5V2h6.5"/></svg>
          </button>
          <a id="pd-lb-remix" href="#" title="Remix" class="flex size-8 shrink-0 items-center justify-center rounded-full" style="background:var(--pd-bg2);border:0.5px solid var(--pd-hairline2);color:var(--pd-ink2);">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 11l9-9M8 2h3v3M5 11H2V8"/></svg>
          </a>
          <div style="flex:1;"></div>
          <button type="button" id="pd-lb-delete" title="Delete" class="flex size-8 shrink-0 items-center justify-center rounded-full" style="background:transparent;border:0.5px solid color-mix(in srgb,var(--pd-pink) 40%,transparent);color:var(--pd-pink);cursor:pointer;">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M1.5 3h9M4 3V2h4v1M4.5 5v4.5M7.5 5v4.5M2.5 3l.5 7.5h6l.5-7.5"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Confirm dialog (replaces browser confirm()) -->
  <div id="pd-confirm" class="fixed inset-0 z-[280] items-center justify-center p-4" style="display:none;background:rgba(5,5,8,0.65);backdrop-filter:blur(8px);">
    <div class="w-full rounded-2xl" style="max-width:300px;padding:20px 22px;background:var(--pd-raised);border:0.5px solid var(--pd-hairline2);">
      <p id="pd-confirm-msg" class="text-ink" style="font-size:13.5px;line-height:1.5;margin-bottom:16px;"></p>
      <div class="grid grid-cols-2 gap-2">
        <button id="pd-confirm-yes" type="button" class="rounded-xl font-semibold" style="padding:9px;background:transparent;border:0.5px solid color-mix(in srgb,var(--pd-pink) 50%,transparent);color:var(--pd-pink);font-size:12.5px;cursor:pointer;">Delete</button>
        <button id="pd-confirm-no" type="button" class="rounded-xl font-semibold" style="padding:9px;background:var(--pd-bg2);border:0.5px solid var(--pd-hairline);color:var(--pd-ink2);font-size:12.5px;cursor:pointer;">Cancel</button>
      </div>
    </div>
  </div>

  <script type="application/json" id="pd-gallery-data" is:inline set:html={JSON.stringify(items)}></script>

  <style>
    .pd-gtab { background: var(--pd-bg2); color: var(--pd-ink-2, var(--pd-ink2)); border: 0.5px solid var(--pd-hairline); }
    .pd-gtab[data-active="true"] { background: var(--pd-ink); color: var(--pd-bg); border-color: transparent; }
    #pd-lb.open { display: flex; }
    /* Select mode */
    #pd-gallery[data-select="false"] .pd-sel-check { display: none; }
    #pd-gallery[data-select="true"] .pd-qd-btn { display: none !important; }
    .pd-gcard[data-selected="true"] { outline: 2.5px solid var(--pd-lilac); outline-offset: -2.5px; }
    .pd-gcard[data-selected="true"] .pd-sel-check { background: var(--pd-lilac) !important; border-color: var(--pd-lilac) !important; }
  </style>

  <script>
    interface Item { id: string; idx: number; type: string; kind: string; output_url: string; template_id: string | null; created: string; template_title: string | null; prompt: string | null; }

    const all: Item[] = JSON.parse(document.getElementById("pd-gallery-data")?.textContent || "[]");
    if (!all.length) { /* empty state, nothing to wire */ } else {

    const gallery = document.getElementById("pd-gallery")!;
    const lb = document.getElementById("pd-lb")!;
    const media = document.getElementById("pd-lb-media")!;
    const kindEl = document.getElementById("pd-lb-kind")!;
    const titleEl = document.getElementById("pd-lb-title")!;
    const metaEl = document.getElementById("pd-lb-meta")!;
    const dlLink = document.getElementById("pd-lb-download") as HTMLAnchorElement;
    const remixLink = document.getElementById("pd-lb-remix") as HTMLAnchorElement;
    const copyPromptBtn = document.getElementById("pd-lb-copy-prompt") as HTMLButtonElement;
    const toolbarNormal = document.getElementById("pd-toolbar-normal")!;
    const toolbarSelect = document.getElementById("pd-toolbar-select")!;
    const selCountEl = document.getElementById("pd-sel-count")!;
    const bulkDownloadBtn = document.getElementById("pd-bulk-download") as HTMLButtonElement;
    const bulkDeleteBtn = document.getElementById("pd-bulk-delete") as HTMLButtonElement;

    const deleted = new Set<string>();
    const selected = new Set<string>();
    let activeTab = "All";
    let searchQuery = "";
    let visible: Item[] = all.slice();
    let cur = 0;
    let selectMode = false;

    function refreshVisible() {
      const q = searchQuery.toLowerCase();
      visible = all.filter(it => {
        if (deleted.has(it.id)) return false;
        if (activeTab !== "All" && (activeTab === "Video" ? it.type !== "video" : it.type === "video")) return false;
        if (q) {
          const hay = ((it.prompt ?? "") + " " + (it.template_title ?? "")).toLowerCase();
          if (!hay.includes(q)) return false;
        }
        return true;
      });
    }

    // ── Confirm modal ─────────────────────────────────────────
    const confirmEl = document.getElementById("pd-confirm")!;
    const confirmMsgEl = document.getElementById("pd-confirm-msg")!;
    const confirmYesEl = document.getElementById("pd-confirm-yes") as HTMLButtonElement;
    const confirmNoEl = document.getElementById("pd-confirm-no") as HTMLButtonElement;
    let _confirmRes: ((v: boolean) => void) | null = null;
    function pdConfirm(msg: string): Promise<boolean> {
      return new Promise(resolve => { confirmMsgEl.textContent = msg; confirmEl.style.display = "flex"; _confirmRes = resolve; });
    }
    [confirmYesEl, confirmNoEl].forEach((btn, i) => btn.addEventListener("click", () => { confirmEl.style.display = "none"; _confirmRes?.(i === 0); _confirmRes = null; }));
    confirmEl.addEventListener("click", e => { if (e.target === confirmEl) { confirmEl.style.display = "none"; _confirmRes?.(false); _confirmRes = null; } });

    // ── Lightbox ──────────────────────────────────────────────
    function render() {
      const it = visible[cur];
      if (!it) return;
      media.innerHTML = "";
      if (it.type === "video") {
        const v = Object.assign(document.createElement("video"), { src: it.output_url, controls: true, playsInline: true, loop: true, autoplay: true, muted: true });
        v.style.cssText = "width:100%;height:100%;max-height:calc(100vh - 48px);object-fit:contain;";
        media.appendChild(v);
      } else {
        const img = Object.assign(document.createElement("img"), { src: it.output_url, alt: it.template_title ?? it.kind });
        img.style.cssText = "width:100%;height:100%;max-height:calc(100vh - 48px);object-fit:contain;";
        media.appendChild(img);
      }
      kindEl.textContent = it.kind + " · saved";
      titleEl.textContent = it.template_title || it.kind;
      metaEl.textContent = `${it.type === "video" ? "Video" : "Image"} · ${it.created}`;
      dlLink.href = `/api/download?id=${it.id}`;
      remixLink.href = it.template_id ? `/studio/${it.template_id}` : "/";
      const hasPrompt = !!it.prompt;
      copyPromptBtn.style.display = hasPrompt ? "flex" : "none";
    }

    function openLb(id: string) {
      if (selectMode) return;
      const idx = visible.findIndex(v => v.id === id);
      if (idx < 0) return;
      cur = idx;
      render();
      lb.classList.add("open");
      document.body.style.overflow = "hidden";
    }

    function closeLb() {
      lb.classList.remove("open");
      document.body.style.overflow = "";
      media.innerHTML = "";
    }

    document.getElementById("pd-lb-close")!.addEventListener("click", closeLb);
    lb.addEventListener("click", e => { if (e.target === lb) closeLb(); });
    document.getElementById("pd-lb-prev")!.addEventListener("click", () => { cur = (cur - 1 + visible.length) % visible.length; render(); });
    document.getElementById("pd-lb-next")!.addEventListener("click", () => { cur = (cur + 1) % visible.length; render(); });
    window.addEventListener("keydown", e => {
      if (!lb.classList.contains("open")) return;
      if (e.key === "Escape") closeLb();
      if (e.key === "ArrowLeft") { cur = (cur - 1 + visible.length) % visible.length; render(); }
      if (e.key === "ArrowRight") { cur = (cur + 1) % visible.length; render(); }
    });
    document.getElementById("pd-lb-share")!.addEventListener("click", () => {
      navigator.clipboard?.writeText(visible[cur]?.output_url ?? "").catch(() => {});
      (window as any).pdToast?.("Link copied", { accent: "var(--pd-mint)" });
    });
    copyPromptBtn.addEventListener("click", () => {
      const p = visible[cur]?.prompt;
      if (!p) return;
      navigator.clipboard?.writeText(p).catch(() => {});
      (window as any).pdToast?.("Prompt copied", { accent: "var(--pd-mint)" });
    });

    // ── Delete ────────────────────────────────────────────────
    async function deleteItem(id: string): Promise<boolean> {
      const res = await fetch("/api/generations/delete", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ id }) });
      if (!res.ok) return false;
      deleted.add(id);
      document.querySelector<HTMLElement>(`.pd-gcard[data-id="${id}"]`)?.remove();
      document.querySelectorAll<HTMLElement>(".pd-day-group").forEach(g => {
        if (!g.querySelector(".pd-gcard")) g.remove();
      });
      refreshVisible();
      (window as any).pdToast?.("Deleted", { accent: "var(--pd-pink)" });
      return true;
    }

    document.getElementById("pd-lb-delete")!.addEventListener("click", async () => {
      if (!await pdConfirm("Delete this creation? This can't be undone.")) return;
      const id = visible[cur]?.id;
      if (!id) return;
      const ok = await deleteItem(id);
      if (!ok) return;
      if (!visible.length) return closeLb();
      cur = Math.min(cur, visible.length - 1);
      render();
    });

    // ── Quick-delete on card ──────────────────────────────────
    document.querySelectorAll<HTMLElement>(".pd-qd-btn").forEach(btn => {
      btn.addEventListener("click", async e => {
        e.stopPropagation();
        await deleteItem(btn.dataset.id!);
      });
    });

    // ── Card clicks ───────────────────────────────────────────
    document.querySelectorAll<HTMLElement>(".pd-gcard").forEach(card => {
      card.addEventListener("click", () => {
        const id = card.dataset.id!;
        if (selectMode) {
          if (selected.has(id)) selected.delete(id);
          else selected.add(id);
          updateSelectionUI();
        } else {
          openLb(id);
        }
      });
    });

    // ── Tab filter ────────────────────────────────────────────
    document.querySelectorAll<HTMLElement>(".pd-gtab").forEach(tab => {
      tab.addEventListener("click", () => {
        activeTab = tab.dataset.tab!;
        document.querySelectorAll<HTMLElement>(".pd-gtab").forEach(x => x.setAttribute("data-active", String(x === tab)));
        document.querySelectorAll<HTMLElement>(".pd-gcard").forEach(card => {
          const t = card.dataset.type;
          const show = activeTab === "All" || (activeTab === "Video" ? t === "video" : t !== "video");
          card.style.display = show ? "" : "none";
        });
        document.querySelectorAll<HTMLElement>(".pd-day-group").forEach(g => {
          const anyVisible = Array.from(g.querySelectorAll<HTMLElement>(".pd-gcard")).some(c => c.style.display !== "none");
          g.style.display = anyVisible ? "" : "none";
        });
        refreshVisible();
        cur = 0;
      });
    });

    // ── Select mode ───────────────────────────────────────────
    function updateSelectionUI() {
      const count = selected.size;
      selCountEl.textContent = `${count} selected`;
      bulkDeleteBtn.style.display = count > 0 ? "" : "none";
      bulkDownloadBtn.style.display = count > 0 ? "" : "none";
      document.querySelectorAll<HTMLElement>(".pd-gcard").forEach(card => {
        const sel = selected.has(card.dataset.id!);
        card.setAttribute("data-selected", sel ? "true" : "false");
      });
    }

    function setSelectMode(on: boolean) {
      selectMode = on;
      gallery.setAttribute("data-select", on ? "true" : "false");
      toolbarNormal.style.display = on ? "none" : "";
      toolbarSelect.style.display = on ? "flex" : "none";
      if (!on) { selected.clear(); updateSelectionUI(); }
    }

    document.getElementById("pd-select-toggle")!.addEventListener("click", () => setSelectMode(true));
    document.getElementById("pd-select-cancel")!.addEventListener("click", () => setSelectMode(false));
    document.getElementById("pd-select-all")!.addEventListener("click", () => {
      visible.forEach(it => selected.add(it.id));
      updateSelectionUI();
    });

    // ── Bulk delete ───────────────────────────────────────────
    bulkDeleteBtn.addEventListener("click", async () => {
      const ids = [...selected];
      if (!ids.length) return;
      if (!await pdConfirm(`Delete ${ids.length} creation${ids.length === 1 ? "" : "s"}? This can't be undone.`)) return;
      bulkDeleteBtn.disabled = true;
      bulkDeleteBtn.textContent = "Deleting…";
      await Promise.all(ids.map(id =>
        fetch("/api/generations/delete", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ id }) }).then(r => {
          if (r.ok) {
            deleted.add(id);
            selected.delete(id);
            document.querySelector<HTMLElement>(`.pd-gcard[data-id="${id}"]`)?.remove();
          }
        })
      ));
      document.querySelectorAll<HTMLElement>(".pd-day-group").forEach(g => {
        if (!g.querySelector(".pd-gcard")) g.remove();
      });
      refreshVisible();
      (window as any).pdToast?.(`Deleted ${ids.length} creation${ids.length === 1 ? "" : "s"}`, { accent: "var(--pd-pink)" });
      setSelectMode(false);
    });

    // ── Bulk download ─────────────────────────────────────────
    bulkDownloadBtn.addEventListener("click", async () => {
      const ids = [...selected];
      if (!ids.length) return;
      bulkDownloadBtn.disabled = true;
      bulkDownloadBtn.textContent = `Downloading…`;
      let n = 0;
      for (const id of ids) {
        const it = all.find(x => x.id === id);
        if (!it) continue;
        const ext = it.type === "video" ? "mp4" : "jpg";
        try {
          const blob = await fetch(`/api/download?id=${it.id}`).then(r => r.blob());
          const a = Object.assign(document.createElement("a"), { href: URL.createObjectURL(blob), download: `pixiedust-${++n}.${ext}` });
          a.click();
          URL.revokeObjectURL(a.href);
          await new Promise(r => setTimeout(r, 250));
        } catch { window.open(`/api/download?id=${it.id}`, "_blank"); }
      }
      bulkDownloadBtn.disabled = false;
      bulkDownloadBtn.textContent = "Download";
      (window as any).pdToast?.(`Downloaded ${ids.length} file${ids.length === 1 ? "" : "s"}`, { accent: "var(--pd-mint)" });
    });

    // ── Search ────────────────────────────────────────────────
    document.getElementById("pd-search")?.addEventListener("input", e => {
      searchQuery = (e.target as HTMLInputElement).value.trim();
      const q = searchQuery.toLowerCase();
      document.querySelectorAll<HTMLElement>(".pd-gcard").forEach(card => {
        const it = all.find(x => x.id === card.dataset.id);
        const tabMatch = activeTab === "All" || (activeTab === "Video" ? card.dataset.type === "video" : card.dataset.type !== "video");
        const searchMatch = !q || ((it?.prompt ?? "") + " " + (it?.template_title ?? "")).toLowerCase().includes(q);
        card.style.display = tabMatch && searchMatch ? "" : "none";
      });
      document.querySelectorAll<HTMLElement>(".pd-day-group").forEach(g => {
        g.style.display = Array.from(g.querySelectorAll<HTMLElement>(".pd-gcard")).some(c => c.style.display !== "none") ? "" : "none";
      });
      refreshVisible();
      cur = 0;
    });

    } // end if all.length
  </script>
</AppShell>
