---
export const prerender = false;
import AppShell from "../layouts/AppShell.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import FilterableCatalog from "../components/catalog/FilterableCatalog.astro";
import { listTemplates, templateToCard } from "../lib/templates";

const db = Astro.locals.runtime.env.DB;
const items = (await listTemplates(db, { featured: true, limit: 24 })).map(templateToCard);
---

<AppShell title="Trending — PixieDust" credits={Astro.locals.user?.credits ?? 47}>
  <div class="mx-auto w-full" style="max-width:1480px;padding:28px;">
    <PageHeader
      kicker="Updated weekly · this week"
      title="Trending"
      sub="What's working right now — across every tool. Most-used wins."
    />
    <FilterableCatalog items={items} aspect="1 / 1.25" />
  </div>
</AppShell>
